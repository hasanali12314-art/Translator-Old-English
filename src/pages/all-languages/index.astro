---
import Layout from '../../layouts/Layout.astro';
import TranslatorTool from '../../components/TranslatorTool.astro';
const languages = [
  'Afrikaans','Albanian','Amharic','Arabic','Armenian','Azerbaijani','Basque','Belarusian','Bengali',
  'Bosnian','Bulgarian','Catalan','Cebuano','Chinese (Simplified)','Chinese (Traditional)','Corsican',
  'Croatian','Czech','Danish','Dutch','English','Esperanto','Estonian','Finnish','French','Frisian',
  'Galician','Georgian','German','Greek','Gujarati','Haitian Creole','Hausa','Hawaiian','Hebrew',
  'Hindi','Hmong','Hungarian','Icelandic','Igbo','Indonesian','Irish','Italian','Japanese','Javanese',
  'Kannada','Kazakh','Khmer','Korean','Kurdish','Kyrgyz','Lao','Latin','Latvian','Lithuanian',
  'Luxembourgish','Macedonian','Malagasy','Malay','Malayalam','Maltese','Maori','Marathi','Mongolian',
  'Myanmar','Nepali','Norwegian','Nyanja','Odia','Pashto','Persian','Polish','Portuguese','Punjabi',
  'Romanian','Russian','Samoan','Scots Gaelic','Serbian','Sesotho','Shona','Sindhi','Sinhala','Slovak',
  'Slovenian','Somali','Spanish','Sundanese','Swahili','Swedish','Tagalog','Tajik','Tamil','Telugu',
  'Thai','Turkish','Ukrainian','Urdu','Uyghur','Uzbek','Vietnamese','Welsh','Xhosa','Yiddish','Yoruba','Zulu'
];

const dedicatedPages: Record<string, string> = {
  'Chinese (Simplified)': 'chinese-translator',
  'Chinese (Traditional)': 'chinese-translator',
  'Arabic': 'arabic-translator',
  'Spanish': 'spanish-translator',
  'Greek': 'greek-translator',
  'German': 'german-translator',
  'French': 'french-translator',
  'Haitian Creole': 'creole-translator',
  'Sinhala': 'sinhala-translator',
  'Latin': 'latin-translator',
};

function langHref(name: string): string {
  const page = dedicatedPages[name];
  if (page) return `/${page}/`;
  return `/all-languages/?to=${encodeURIComponent(name)}`;
}
---
<Layout title="All Language Translator — Translate Any Language Online Free" description="Translate English to any language or any language to English — instant, free, AI-powered. 100+ languages supported." canonical="/all-languages/">
<section class="hero-section">
  <div class="container">
    <nav class="breadcrumb" style="margin-bottom:16px">
      <a href="/translator-old-english/">Home</a><span>›</span><span>All Languages Translator</span>
    </nav>
    <a href="/translator-old-english/" class="btn btn-ghost btn-sm" style="margin-bottom:24px">← Back to Home</a>
    <h1 id="main-heading">All Language <span class="gold-text">Translator</span></h1>
    <p class="hero-sub">Translate English to any language or any language to English — instant, free, AI-powered</p>
  </div>
</section>

<section class="section-sm">
  <div class="container">
    <TranslatorTool
      inputLabel="Source Language"
      outputLabel="Target Language"
      inputPlaceholder="Type or paste your text here (up to 5000 characters)..."
      outputPlaceholder="Your translation will appear here..."
      sourceLang="en"
      targetLang="es"
      sourceLanguages={['Auto-detect / Any Language', ...languages]}
      targetLanguages={['English', ...languages.filter(l => l !== 'English')]}
    />
  </div>
</section>

<!-- Examples -->
<section class="section-sm">
  <div class="container">
    <div class="section-heading"><h2>Translation <span class="gold-text">Examples</span></h2></div>
    <div class="grid-3">
      {[
        {from:'Spanish',src:'Buenos días, ¿cómo estás hoy?',eng:'Good morning, how are you today?'},
        {from:'French',src:'Je t\'aime de tout mon cœur.',eng:'I love you with all my heart.'},
        {from:'Chinese',src:'今天天气很好。',eng:'The weather is very nice today.'},
      ].map(ex => (
        <div class="example-card">
          <div class="example-card-section">
            <div class="example-label">{ex.from}</div>
            <div class="example-text">{ex.src}</div>
          </div>
          <div class="example-card-section">
            <div class="example-label">English</div>
            <div class="example-text" style="color:var(--gold-light)">{ex.eng}</div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Languages Directory -->
<section class="section">
  <div class="container">
    <div class="section-heading"><h2>All <span class="gold-text">Supported Languages</span></h2>
    <p style="color:var(--text-muted);margin-top:8px">Click a language to translate English into that language</p></div>
    <div class="grid-auto">
      {languages.filter(l => l !== 'English').map(l => (
        <a href={langHref(l)} class="card lang-card" style="text-align:center;padding:16px;font-weight:500;text-decoration:none;color:var(--text-secondary)" aria-label={`Translate to ${l}`}>
          {l}
        </a>
      ))}
    </div>
  </div>
</section>

<!-- Content -->
<section class="section">
  <div class="container" style="max-width:800px">
    <h2 style="margin-bottom:20px">Translate Any Language <span class="gold-text">to English</span></h2>
    <p style="color:var(--text-secondary);line-height:1.8;margin-bottom:40px">Select the source language (or Auto-detect), choose English as the target, paste your text, and click Translate. The tool detects many scripts automatically when Auto-detect is selected.</p>

    <h2 style="margin-bottom:20px">English to All Languages — <span class="gold-text">Free Online Translator</span></h2>
    <p style="color:var(--text-secondary);line-height:1.8;margin-bottom:40px">Click any language above to open the translator with that target pre-selected, or use the dropdowns. This free online translator covers Germanic, Romance, Slavic, Asian, Semitic, and many other language families.</p>

    <h2 style="margin-bottom:20px">How to Use the <span class="gold-text">All Language Translator</span></h2>
    {['Select your source language or leave it on Auto-detect','Select your target language — or click a language card below','Type or paste your text into the input box (up to 5000 characters)','Click Translate — the result appears instantly','Use the flip button to reverse source and target languages'].map((s,i) => (
      <div style="display:flex;gap:16px;margin-bottom:16px;padding:16px;background:var(--surface);border:1px solid var(--border);border-radius:var(--radius-md)">
        <span style="font-weight:700;color:var(--gold);opacity:0.5;min-width:28px">0{i+1}</span>
        <span style="color:var(--text-secondary)">{s}</span>
      </div>
    ))}
  </div>
</section>

<!-- Related -->
<section class="section-sm">
  <div class="container">
    <div class="section-heading"><h2>Related <span class="gold-text">Pages</span></h2></div>
    <div class="grid-3">
      {[
        {href:'/text-translator/',icon:'📝',title:'Text Translator',desc:'Word and sentence-level translation'},
        {href:'/translator-old-english/',icon:'⚜️',title:'Translator Old English',desc:'Translate to historical English styles'},
        {href:'/language-translators/',icon:'🌍',title:'Language Translators',desc:'Browse all individual language pages'},
      ].map(r => (
        <a href={r.href} class="card card-gold" style="text-decoration:none;display:block">
          <span style="display:block;margin-bottom:10px">{r.icon}</span>
          <h3 style="margin-bottom:6px">{r.title}</h3>
          <p style="color:var(--text-secondary)">{r.desc}</p>
        </a>
      ))}
    </div>
  </div>
</section>

<!-- FAQ -->
<section class="section">
  <div class="container" style="max-width:800px">
    <div class="section-heading"><h2>Frequently Asked <span class="gold-text">Questions</span></h2></div>
    {[
      {q:'Can I translate any language to English for free?',a:'Yes. Use Auto-detect as the source and English as the target, or select the source language manually. Translation is completely free.'},
      {q:'How do I translate English to another language?',a:'Click any language in the grid below, or select English as source and your target language in the dropdowns, then click Translate.'},
      {q:'What is an all language translator?',a:'An all language translator supports translation between any combination of 100+ languages — not just between two fixed languages.'},
      {q:'Is the all languages translator free to use?',a:'Completely free. No account, no subscription required.'},
      {q:'What is the character limit for translation?',a:'Each translation supports up to 5,000 characters. Split longer texts into sections for best results.'},
      {q:'Does the tool save my translation history?',a:'Yes. Your last 50 translations are stored in your browser\'s local storage.'},
      {q:'Can I use the translations commercially?',a:'Yes. All translations can be used in personal and commercial projects.'},
    ].map(f => (
      <div class="faq-item">
        <button class="faq-question">{f.q}<span class="faq-icon">+</span></button>
        <div class="faq-answer">{f.a}</div>
      </div>
    ))}
  </div>
</section>

<!-- CTA -->
<section class="section-sm">
  <div class="container">
    <div class="cta-banner">
      <h2 style="margin-bottom:16px">Translate <span class="gold-text">Any Language</span> Now</h2>
      <p style="color:var(--text-secondary);margin-bottom:32px">Free, instant — no account needed</p>
      <a href="#tool-area" class="btn btn-primary btn-lg" style="margin-bottom:32px">✦ Start Translating</a>
      <div class="trust-badges">
        <div class="trust-badge"><div class="trust-badge-icon">🆓</div> Free forever</div>
        <div class="trust-badge"><div class="trust-badge-icon">⚡</div> Instant results</div>
        <div class="trust-badge"><div class="trust-badge-icon">🌍</div> 100+ languages</div>
      </div>
    </div>
  </div>
</section>
</Layout>
