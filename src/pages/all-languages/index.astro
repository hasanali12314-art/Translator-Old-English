---
import Layout from '../../layouts/Layout.astro';
import TranslatorTool from '../../components/TranslatorTool.astro';

const languages = [
  'Afrikaans','Albanian','Amharic','Arabic','Armenian','Azerbaijani','Basque','Belarusian','Bengali',
  'Bosnian','Bulgarian','Catalan','Cebuano','Chinese (Simplified)','Chinese (Traditional)','Corsican',
  'Croatian','Czech','Danish','Dutch','English','Esperanto','Estonian','Finnish','French','Frisian',
  'Galician','Georgian','German','Greek','Gujarati','Haitian Creole','Hausa','Hawaiian','Hebrew',
  'Hindi','Hmong','Hungarian','Icelandic','Igbo','Indonesian','Irish','Italian','Japanese','Javanese',
  'Kannada','Kazakh','Khmer','Korean','Kurdish','Kyrgyz','Lao','Latin','Latvian','Lithuanian',
  'Luxembourgish','Macedonian','Malagasy','Malay','Malayalam','Maltese','Maori','Marathi','Mongolian',
  'Myanmar','Nepali','Norwegian','Nyanja','Odia','Pashto','Persian','Polish','Portuguese','Punjabi',
  'Romanian','Russian','Samoan','Scots Gaelic','Serbian','Sesotho','Shona','Sindhi','Sinhala','Slovak',
  'Slovenian','Somali','Spanish','Sundanese','Swahili','Swedish','Tagalog','Tajik','Tamil','Telugu',
  'Thai','Turkish','Ukrainian','Urdu','Uyghur','Uzbek','Vietnamese','Welsh','Xhosa','Yiddish','Yoruba','Zulu'
];

const dedicatedPages: Record<string, string> = {
  'Chinese (Simplified)': 'chinese-translator',
  'Chinese (Traditional)': 'chinese-translator',
  'Arabic': 'arabic-translator',
  'Spanish': 'spanish-translator',
  'Greek': 'greek-translator',
  'German': 'german-translator',
  'French': 'french-translator',
  'Haitian Creole': 'creole-translator',
  'Sinhala': 'sinhala-translator',
  'Latin': 'latin-translator',
};

const examples = [
  { inputLabel: 'Spanish', outputLabel: 'English', input: 'Buenos días, ¿cómo estás hoy?', output: 'Good morning, how are you today?' },
  { inputLabel: 'French', outputLabel: 'English', input: "Je t'aime de tout mon cœur.", output: 'I love you with all my heart.' },
  { inputLabel: 'Chinese', outputLabel: 'English', input: '今天天气很好。', output: 'The weather is very nice today.' },
];

const related = [
  { href: '/', icon: '⚜️', title: 'Translator Old English', desc: 'Translate to historical English styles' },
  { href: '/language-translators/', icon: '🌍', title: 'Language Translators', desc: 'Browse all individual language pages' },
  { href: '/translation-tools/', icon: '🛠️', title: 'Translation Tools', desc: 'Browse all free translation tools' },
];

function langSlug(name: string): string {
  return name.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
}

function langHref(name: string): string {
  const page = dedicatedPages[name];
  if (page) return `/${page}/`;
  return `/all-languages/#lang-${langSlug(name)}`;
}
---
<Layout title="All Language Translator — Translate Any Language Online Free" description="Translate English to any language or any language to English — instant, free, AI-powered. 100+ languages supported." canonical="/all-languages/">
  <Fragment slot="head">
    <script src="/all-languages-lang.js" defer></script>
  </Fragment>
  <div class="container container--page tool-page">
    <div class="hero hero-section">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span aria-hidden="true">›</span>
        <span>All Languages Translator</span>
      </nav>
      <a href="/" class="tool-page-back btn btn-ghost btn-sm">← Back to Home</a>
      <h1 id="main-heading">All Language <span class="gold-text">Translator</span></h1>
      <p class="hero-sub">Translate English to any language or any language to English — instant, free, AI-powered</p>
      <div class="hero-line"></div>
    </div>

    <TranslatorTool
      inputLabel="Source Language"
      outputLabel="Target Language"
      inputPlaceholder="Type or paste your text here (up to 5000 characters)..."
      outputPlaceholder="Your translation will appear here..."
      sourceLang="en"
      targetLang="es"
      sourceLanguages={['Auto-detect / Any Language', ...languages]}
      targetLanguages={['English', ...languages.filter(l => l !== 'English')]}
    />

    <section class="page-section page-section--examples">
      <div class="sec-head">
        <h2 class="sec-title">Translation Examples</h2>
        <div class="sec-line"></div>
      </div>
      <div class="ex-grid grid-3">
        {examples.map((ex) => (
          <div class="ex-card example-card">
            <div class="ex-tag example-label">{ex.inputLabel}</div>
            <div class="ex-modern example-text">{ex.input}</div>
            <div class="ex-hr"></div>
            <div class="ex-tag example-label">{ex.outputLabel}</div>
            <div class="ex-old example-text">{ex.output}</div>
          </div>
        ))}
      </div>
    </section>

    <section class="page-section">
      <div class="sec-head">
        <h2 class="sec-title">All Supported Languages</h2>
        <div class="sec-line"></div>
      </div>
      <p class="sec-sub">Click a language to translate English into that language</p>
      <div class="grid-auto">
        {languages.filter(l => l !== 'English').map(l => (
          <a
            href={langHref(l)}
            class="card lang-card"
            data-lang={l}
            data-lang-slug={langSlug(l)}
            style="text-align:center;padding:16px;font-weight:500;text-decoration:none;color:var(--text-secondary)"
            aria-label={`Translate to ${l}`}
          >
            {l}
          </a>
        ))}
      </div>
    </section>

    <section class="page-section page-section--guide">
      <div class="info-block">
        <h2>Translate Any Language <span class="gold-text">to English</span></h2>
        <p>Select the source language (or Auto-detect), choose English as the target, paste your text, and click Translate. The tool detects many scripts automatically when Auto-detect is selected.</p>

        <h2>English to All Languages — <span class="gold-text">Free Online Translator</span></h2>
        <p>Click any language above to open the translator with that target pre-selected, or use the dropdowns. This free online translator covers Germanic, Romance, Slavic, Asian, Semitic, and many other language families.</p>

        <h2>How to Use the <span class="gold-text">All Language Translator</span></h2>
        {['Select your source language or leave it on Auto-detect','Select your target language — or click a language card below','Type or paste your text into the input box (up to 5000 characters)','Click Translate — the result appears instantly','Use the flip button to reverse source and target languages'].map((s, i) => (
          <div style="display:flex;gap:16px;margin-bottom:16px;padding:16px;background:var(--surface);border:1px solid var(--border);border-radius:var(--radius-md)">
            <span style="font-weight:700;color:var(--gold);opacity:0.5;min-width:28px">0{i + 1}</span>
            <span style="color:var(--text-secondary)">{s}</span>
          </div>
        ))}
      </div>

      <div class="info-block">
        <h3>Related Pages</h3>
        <div class="grid-3 related-grid">
          {related.map(r => (
            <a href={r.href} class="card card-gold related-card" style="text-decoration:none;display:block">
              <span style="display:block;margin-bottom:10px">{r.icon}</span>
              <h3 style="margin-bottom:6px">{r.title}</h3>
              <p style="color:var(--text-secondary)">{r.desc}</p>
            </a>
          ))}
        </div>
      </div>

      <div class="cta cta-banner">
        <div class="cta-top"></div>
        <h2>Translate <span class="gold-text">Any Language</span> Now</h2>
        <p>Free, instant — no account needed</p>
        <a href="#tool-area" class="cta-btn btn btn-primary btn-lg">✦ Start Translating</a>
        <div class="trust-badges">
          <div class="badge"><span>♾️</span> Free forever</div>
          <div class="badge"><span>⚡</span> Instant results</div>
          <div class="badge"><span>🌍</span> 100+ languages</div>
        </div>
      </div>
    </section>
  </div>
</Layout>
