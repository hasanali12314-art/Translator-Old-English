---
import Layout from '../../layouts/Layout.astro';
const tools=[
  {href:'/',icon:'⚜️',name:'Translator Old English',desc:'Translate modern English to Early, Middle, Ancient, or Simple Old English styles'},
  {href:'/all-languages/',icon:'🌍',name:'All Languages Translator',desc:'Translate between any language and English — 100+ languages supported'},
  {href:'/latin-translator/',icon:'🏛️',name:'Latin Translator',desc:'Classical and Ecclesiastical Latin translation with style options'},
  {href:'/ancient-greek/',icon:'🏺',name:'Ancient Greek Translator',desc:'Koine and Classical Ancient Greek translation'},
  {href:'/old-english/',icon:'⚔️',name:'Old English (Anglo-Saxon)',desc:'Authentic Anglo-Saxon and Old Norse translation'},
  {href:'/aramaic-translator/',icon:'📜',name:'Aramaic Translator',desc:'Biblical Aramaic and Coptic translation'},
  {href:'/dialect-translator/',icon:'🗣️',name:'Dialect Converter',desc:'Convert standard English to regional dialects'},
  {href:'/fancy-translator/',icon:'✨',name:'Fancy Text Converter',desc:'Stylised and decorative Unicode text styles'},
  {href:'/rare-languages/',icon:'💎',name:'Rare Language Converter',desc:'Minority and endangered language translation'},
  {href:'/navajo-translator/',icon:'🪶',name:'Navajo Converter',desc:'English to Navajo (Diné Bizaad) translation'},
  {href:'/sinhala-translator/',icon:'🇱🇰',name:'Sinhala Translator',desc:'English to Sinhala native script translation'},
];
---
<Layout title="Translation Tools — All Free Online Translation Tools" description="Browse all free AI-powered translation tools on Translator Old English. Old English, Latin, Ancient Greek, dialects, rare languages and more." canonical="/translation-tools/">
<section class="hero-section"><div class="container">
  <h1 id="main-heading">Translation <span class="gold-text">Tools</span></h1>
  <p class="hero-sub">All free AI-powered translation tools in one place</p>
</div></section>
<section class="section"><div class="container">
  <div class="section-heading"><h2>All <span class="gold-text">Available Tools</span></h2></div>
  <div class="grid-3">
    {tools.map(t=>(<a href={t.href} class="card" style="text-decoration:none;display:block">
      <div style="margin-bottom:10px">{t.icon}</div>
      <h3 style="margin-bottom:6px">{t.name}</h3>
      <p style="color:var(--text-secondary)">{t.desc}</p>
      <div style="color:var(--gold);margin-top:12px;font-weight:600">Use Tool →</div>
    </a>))}
  </div>
</div></section>
<section class="section-sm"><div class="container" style="max-width:800px">
  <h2 style="margin-bottom:16px">Why These <span class="gold-text">Tools?</span></h2>
  <p style="color:var(--text-secondary);line-height:1.8;margin-bottom:20px">Every tool on this site is designed to be genuinely useful, historically informed, and completely free. From mainstream language pairs to rare and ancient languages, the focus is on quality, accuracy, and accessibility. All tools store history locally and never require an account.</p>
  <div style="display:flex;gap:16px;flex-wrap:wrap">
    <a href="/blog/" class="btn btn-outline">Read the Blog</a>
    <a href="/" class="btn btn-ghost">Try Old English Tool</a>
    <a href="/tools-resources/" class="btn btn-ghost">Back to Resources</a>
  </div>
</div></section>
</Layout>
