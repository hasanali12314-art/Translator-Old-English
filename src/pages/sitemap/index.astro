---
import Layout from '../../layouts/Layout.astro';
import { BLOG_POSTS } from '../../data/siteConfig';

const mainPages = [
  { name: 'Old English translator', href: '/' },
  { name: 'Blog', href: '/blog/' },
  { name: 'About us', href: '/about-us/' },
  { name: 'Sitemap', href: '/sitemap/' },
];

const legalPages = [
  { name: 'Privacy policy', href: '/privacy-policy/' },
  { name: 'Terms and conditions', href: '/terms-and-conditions/' },
  { name: 'Cookies policy', href: '/cookies/' },
];

const blogPages = BLOG_POSTS.map((p) => ({
  name: p.title.split(/[—:?]/)[0].trim(),
  href: `/blog/${p.slug}/`,
}));
---
<Layout title="Sitemap — Translator Old English" description="Sitemap for Translator Old English — translator, blog articles, and legal pages." canonical="/sitemap/">
<section class="hero-section"><div class="container">
  <h1 id="main-heading">Site <span class="gold-text">map</span></h1>
  <p class="hero-sub">All pages on Translator Old English</p>
</div></section>
<section class="section"><div class="container" style="max-width:900px">
  <p style="margin-bottom:24px;color:var(--text-secondary);line-height:1.8">
    XML sitemap for search engines: <a href="/sitemap.xml">/sitemap.xml</a>
  </p>
  <h2 style="margin-bottom:24px">Browse by <span class="gold-text">section</span></h2>
  <div class="grid-3">
    <div class="card">
      <h3 style="color:var(--gold);margin-bottom:16px">Main</h3>
      <ul style="list-style:none;display:flex;flex-direction:column;gap:8px">
        {mainPages.map((p) => (
          <li><a href={p.href} style="color:var(--text-secondary);text-decoration:none">{p.name}</a></li>
        ))}
      </ul>
    </div>
    <div class="card">
      <h3 style="color:var(--gold);margin-bottom:16px">Blog</h3>
      <ul style="list-style:none;display:flex;flex-direction:column;gap:8px">
        {blogPages.map((p) => (
          <li><a href={p.href} style="color:var(--text-secondary);text-decoration:none">{p.name}</a></li>
        ))}
      </ul>
    </div>
    <div class="card">
      <h3 style="color:var(--gold);margin-bottom:16px">Legal</h3>
      <ul style="list-style:none;display:flex;flex-direction:column;gap:8px">
        {legalPages.map((p) => (
          <li><a href={p.href} style="color:var(--text-secondary);text-decoration:none">{p.name}</a></li>
        ))}
      </ul>
    </div>
  </div>
</div></section>
</Layout>
