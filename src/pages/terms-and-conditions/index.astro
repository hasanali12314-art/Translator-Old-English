---
import Layout from '../../layouts/Layout.astro';
const sections=[
  {title:'Acceptance of Terms',content:'By accessing or using OldEnglish Translator, you agree to be bound by these Terms and Conditions. If you do not agree, please do not use the site.'},
  {title:'Use of the Site',content:'You may use the site for lawful purposes only. You must not use the site to translate content that is illegal, harmful, defamatory, or infringes third-party rights. You must not attempt to reverse-engineer, scrape excessively, or disrupt the service.'},
  {title:'Intellectual Property',content:'The site design, layout, branding, and original content are the property of OldEnglish Translator. Translation output generated by the AI tool is provided for your use and is not claimed as proprietary content of this site.'},
  {title:'User-Generated Content',content:'Text you enter into the translation tool is processed by our AI API. You retain ownership of your input text. By submitting text, you grant us a limited licence to process it for the purpose of returning a translation result.'},
  {title:'Translation Output',content:'All translations are generated by AI and may not be fully accurate, especially for ancient or rare languages. Outputs should not be relied upon for critical medical, legal, or safety purposes without expert verification.'},
  {title:'Third-Party Services',content:'The site uses third-party AI translation APIs, analytics providers, and advertising networks. Use of the site implies acceptance of their respective terms and privacy policies.'},
  {title:'Advertising',content:'This site displays third-party advertisements to fund the free service. We are not responsible for the content of third-party ads. Ad targeting is managed by the ad network in accordance with their privacy policies.'},
  {title:'Disclaimers',content:'The site is provided "as is" without warranties of any kind. We do not guarantee uninterrupted access, error-free operation, or absolute translation accuracy. Use is at your own risk.'},
  {title:'Limitation of Liability',content:'To the fullest extent permitted by law, OldEnglish Translator shall not be liable for any direct, indirect, incidental, or consequential losses arising from use of the site or reliance on translation output.'},
  {title:'Changes to Terms',content:'We reserve the right to update these Terms at any time. Updated terms will be posted on this page. Continued use of the site after changes constitutes acceptance of the revised terms.'},
  {title:'Governing Law',content:'These Terms are governed by the laws of England and Wales. Any disputes shall be subject to the exclusive jurisdiction of the courts of England and Wales.'},
  {title:'Contact',content:'For legal enquiries, please refer to the contact details on the Privacy Policy page. We aim to respond within 48 hours.'},
];
---
<Layout title="Terms and Conditions — OldEnglish Translator" description="Terms and conditions for using OldEnglish Translator. Read our usage terms, IP policy, disclaimers, and governing law." canonical="/terms-and-conditions/">
<section class="hero-section"><div class="container">
  <h1 id="main-heading">Terms &amp; <span class="gold-text">Conditions</span></h1>
  <p class="hero-sub">Please read these terms carefully before using OldEnglish Translator — last updated May 2024</p>
</div></section>
<section class="section"><div class="container" style="max-width:800px;">
  {sections.map((s,i)=>(<div style="margin-bottom:36px;"><h2 style="font-size:1.1rem;margin-bottom:12px;"><span style="color:var(--gold);margin-right:10px;">{i+1}.</span>{s.title}</h2><p style="color:var(--text-secondary);line-height:1.8;">{s.content}</p></div>))}
  <div class="divider"></div>
  <div style="display:flex;gap:16px;flex-wrap:wrap;">
    <a href="/privacy-policy/" class="btn btn-outline">Privacy Policy</a>
    <a href="/cookies/" class="btn btn-ghost">Cookies Policy</a>
    <a href="/translator-old-english/" class="btn btn-ghost">Back to Homepage</a>
  </div>
</div></section>
</Layout>
