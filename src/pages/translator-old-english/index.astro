---
import Layout from '../../layouts/Layout.astro';
---
<Layout
  title="Translator Old English — Free AI Tool (4 Styles: Early, Middle, Ancient & Simple)"
  description="Translator Old English turns any modern text into authentic archaic English instantly. Choose Early (1500s), Middle (1300s), Ancient (800s) or Simple style — free, AI-powered, no signup. 5,000 characters. Try it now →"
  canonical="/translator-old-english/"
>

<div class="container" style="padding-top:44px;padding-bottom:80px">

  <div class="hero hero-section">
    <div class="hero-tag">Free · <span>AI-Powered</span> · Instant · No Signup</div>
    <h1 id="main-heading">Translator <em>Old English</em></h1>
    <p class="hero-sub">Transform modern text into authentic archaic English — four historical styles, free forever</p>
    <div class="hero-line"></div>
  </div>

  <div class="tool-card tool-area" id="tool-area">
    <div class="style-row">
      <div class="field-wrap">
        <label class="field-label" for="style-select">Translation Style</label>
        <select class="select" id="style-select">
          <option value="early">🎭 Shakespeare Style — Early Modern English (1500s–1600s)</option>
          <option value="middle">📜 Medieval Style — Middle English (1300s–1400s)</option>
          <option value="ancient">⚔️ Anglo-Saxon — True Old English (800s–1000s)</option>
          <option value="simple">✨ Archaic Simplified — Easy thee/thou style</option>
        </select>
      </div>
      <button type="button" class="adv-btn" id="advancedToggle" aria-expanded="false">
        ⚙ Advanced <span class="adv-chevron" id="advancedArrow">›</span>
      </button>
    </div>

    <div class="adv-panel advanced-content" id="advancedContent">
      <div class="adv-grid" style="display:grid;grid-template-columns:1fr 1fr;gap:18px">
        <div class="adv-item">
          <label>Formality Level</label>
          <input type="range" class="range-slider" id="formalitySlider" min="1" max="5" value="3" style="width:100%;margin-top:8px">
          <div class="range-labels" style="display:flex;justify-content:space-between;font-size:10px;color:var(--muted-lt);margin-top:3px">
            <span>Casual</span><span>Ceremonial</span>
          </div>
        </div>
        <div class="adv-item">
          <div class="adv-row">
            <label>Old Pronouns (thee/thou)</label>
            <button type="button" class="toggle active" id="pronounToggle" role="switch" aria-checked="true"></button>
          </div>
        </div>
        <div class="adv-item">
          <div class="adv-row">
            <label>Old Verb Endings (-eth, -hath)</label>
            <button type="button" class="toggle active" id="verbToggle" role="switch" aria-checked="true"></button>
          </div>
        </div>
        <div class="adv-item">
          <div class="adv-row">
            <label>Archaic Vocabulary</label>
            <button type="button" class="toggle active" id="vocabToggle" role="switch" aria-checked="true"></button>
          </div>
        </div>
      </div>
    </div>

    <div class="boxes">
      <div class="trans-row" style="display:contents">
        <div class="trans-side">
          <div class="trans-top">
            <span class="trans-lang" id="inLabel">Modern English</span>
            <span class="char-ct"><span id="charCount">0</span> / 5000</span>
          </div>
          <textarea id="input-text" placeholder="Enter your modern text here..." maxlength="5000" aria-label="Input text"></textarea>
        </div>
        <div class="trans-mid">
          <button type="button" class="swap-btn" id="flipBtn" title="Flip direction" aria-label="Flip translation direction">⇄</button>
          <span class="flip-lbl">Flip</span>
        </div>
        <div class="trans-side trans-out">
          <div class="trans-top">
            <span class="trans-lang" id="outLabel">Old English</span>
            <button type="button" class="copy-btn" id="copyBtn" style="opacity:0">⎘ Copy</button>
          </div>
          <textarea id="output-text" readonly placeholder="Thy translation shalt appear here..." aria-label="Translation output" aria-live="polite"></textarea>
        </div>
      </div>
    </div>

    <div class="actions">
      <button type="button" class="btn-clear" id="clearBtn">✕ Clear</button>
      <button type="button" class="btn-translate" id="translateBtn">✦ Translate</button>
    </div>
  </div>

  <div class="sec-head"><h2 class="sec-title">Quick Examples</h2><div class="sec-line"></div></div>
  <p class="sec-sub">Click any card to load it into the translator</p>
  <div class="ex-grid grid-3">
    {[
      {m:'Hello, how are you today?',o:'Hail, how farest thou this day?'},
      {m:"I don't understand what you're saying.",o:'I comprehend not thy words, good fellow.'},
      {m:'Thank you for your help.',o:'I thank thee most heartily for thy aid.'},
    ].map(ex => (
      <div class="ex-card example-card" data-modern={ex.m} data-old={ex.o} role="button" tabindex="0">
        <div class="ex-tag example-label">Modern</div>
        <div class="ex-modern example-text">{ex.m}</div>
        <div class="ex-hr" style="height:1px;background:var(--border);margin:10px 0"></div>
        <div class="ex-tag example-label">Old English</div>
        <div class="ex-old example-text">{ex.o}</div>
      </div>
    ))}
  </div>

  <div class="sec-head"><h2 class="sec-title">Choose Your Style</h2><div class="sec-line"></div></div>
  <p class="sec-sub">Four distinct historical periods — each with its own character</p>
  <div class="sc-grid grid-4">
    {[
      {icon:'🎭',name:'Shakespeare Style',period:'1500s – 1600s',desc:'Early Modern English. Thee, thou, dost, hath. Most readable and widely recognised archaic style.'},
      {icon:'📜',name:'Medieval Style',period:'1300s – 1400s',desc:"Chaucer's era. Older spelling and grammar. Ideal for historical fiction and academic work."},
      {icon:'⚔️',name:'Anglo-Saxon',period:'800s – 1000s',desc:'True Old English. Deeply Germanic, most authentic. Used in Beowulf-era literature.'},
      {icon:'✨',name:'Archaic Simplified',period:'Casual Archaic',desc:'Easy old-timey style. Great for social media, memes, games, and casual use.'},
    ].map(s => (
      <div class="sc-card card">
        <div class="sc-icon">{s.icon}</div>
        <div class="sc-name">{s.name}</div>
        <div class="sc-period">{s.period}</div>
        <div class="sc-desc">{s.desc}</div>
      </div>
    ))}
  </div>

  <div class="info-block">
    <h2>Translator Old English — Complete Guide</h2>
    <p>Translator Old English is the most advanced free AI tool for converting modern English into authentic archaic language styles spanning over a thousand years of English history.</p>
    <div class="feat-grid grid-2">
      {[
        {icon:'🔄',name:'Bidirectional Translation',desc:'Modern to old, or old to modern'},
        {icon:'📚',name:'4 Historical Styles',desc:'Early, Middle, Ancient, Simple'},
        {icon:'🤖',name:'AI-Powered Accuracy',desc:'Context-aware, not word-for-word'},
        {icon:'⚙️',name:'Customisable Output',desc:'Formality, pronouns, endings, vocabulary'},
      ].map(f => (
        <div class="feat">
          <div class="feat-icon">{f.icon}</div>
          <div><div class="feat-name">{f.name}</div><div class="feat-desc">{f.desc}</div></div>
        </div>
      ))}
    </div>
  </div>

  <div class="info-block">
    <h3>Why Use Translator Old English?</h3>
    <div class="benefit-row grid-3">
      {[
        {icon:'⚡',name:'Instant',desc:'Results appear in seconds — no waiting.'},
        {icon:'🎯',name:'Accurate',desc:'Trained on authentic historical texts.'},
        {icon:'♾️',name:'Free Forever',desc:'No account, no limits, no fees.'},
      ].map(b => (
        <div class="benefit">
          <div class="benefit-icon">{b.icon}</div>
          <div class="benefit-name">{b.name}</div>
          <div class="benefit-desc">{b.desc}</div>
        </div>
      ))}
    </div>
  </div>

  <div class="info-block">
    <h3>How Translator Old English Works in 3 Simple Steps</h3>
    <div class="steps">
      {[
        {n:'1',title:'Choose a translation style from the dropdown',desc:'Shakespeare (1500s), Medieval (1300s), Anglo-Saxon (800s), or Archaic Simplified.'},
        {n:'2',title:'Type or paste text into the input box',desc:'Up to 5,000 characters — roughly 800 words.'},
        {n:'3',title:'Click Translate — copy the result',desc:'Result appears instantly. Use History for past translations.'},
      ].map(s => (
        <div class="step">
          <div class="step-num">{s.n}</div>
          <div><div class="step-title">{s.title}</div><div class="step-desc">{s.desc}</div></div>
        </div>
      ))}
    </div>
  </div>

  <div class="info-block">
    <h3>Who Uses Translator Old English?</h3>
    <div class="users-grid grid-2">
      {[
        {title:'✍️ Writers & Authors',desc:'Authentic dialogue for historical fiction and fantasy novels.'},
        {title:'🎮 Game Developers',desc:'Immersive NPC dialogue and lore text for RPGs.'},
        {title:'🎓 Students & Educators',desc:'Study the evolution of English language interactively.'},
        {title:'🎭 Theatre & Film',desc:'Period-accurate scripts and production materials.'},
        {title:'📱 Social Media',desc:'Humorous archaic posts, memes, and content.'},
        {title:'🔍 Curious Users',desc:'Explore a thousand years of English language history.'},
      ].map(u => (
        <div class="user-item">
          <div class="user-title">{u.title}</div>
          <div class="user-desc">{u.desc}</div>
        </div>
      ))}
    </div>
  </div>

  <div class="info-block">
    <h3>Translator Old English — Frequently Asked Questions</h3>
    <div class="faq">
      {[
        {q:'What is the difference between Old English and Middle English?',a:'Old English (Anglo-Saxon, 800–1100 AD) is heavily Germanic and almost unrecognisable today. Middle English (1100–1500 AD), as written by Chaucer, is more familiar. Early Modern English (1500–1700 AD) includes Shakespeare\'s works and is the most readable archaic style.'},
        {q:'Is Translator Old English free to use?',a:'Yes — completely free. No account, no limits, no hidden fees.'},
        {q:'How accurate are the translations?',a:'Translator Old English uses context-aware AI — not word-for-word replacement. Results are authentic and natural-sounding for creative and educational purposes.'},
        {q:'Can I translate old language back to modern?',a:'Yes. Use the ⇄ Flip button between the boxes to switch the translation direction.'},
        {q:'What is the character limit?',a:'Up to 5,000 characters per translation — approximately 800–1,000 words.'},
        {q:'Does Translator Old English save my history?',a:'Yes. Your last 50 translations are saved locally in your browser only — nothing is sent to any server.'},
        {q:'Which style should I choose?',a:'Shakespeare for creative writing, Medieval for historical fiction, Anglo-Saxon for academic use, and Archaic Simplified for social media and casual fun.'},
        {q:'Can I use translations for commercial projects?',a:'Yes — no restrictions. Use the output in books, games, films, or any commercial project without attribution required.'},
      ].map(f => (
        <div class="faq-item">
          <button type="button" class="faq-question faq-q">{f.q} <span class="faq-icon">+</span></button>
          <div class="faq-answer faq-a">{f.a}</div>
        </div>
      ))}
    </div>
  </div>

  <div class="cta cta-banner">
    <div class="cta-top"></div>
    <h2>Begin Thy Translation</h2>
    <p>Free, instant, AI-powered — no signup required</p>
    <a href="#tool-area" class="cta-btn btn btn-primary btn-lg">Start Translating Now</a>
    <div class="trust-badges">
      <div class="badge"><span>♾️</span> Free forever</div>
      <div class="badge"><span>⚡</span> Instant results</div>
      <div class="badge"><span>🎯</span> AI-powered accuracy</div>
    </div>
  </div>

</div>

<script>
  const inputText = document.getElementById('input-text') as HTMLTextAreaElement;
  const charCount = document.getElementById('charCount');
  inputText?.addEventListener('input', () => {
    if (charCount) charCount.textContent = String(inputText.value.length);
  });

  const advancedToggle = document.getElementById('advancedToggle');
  const advancedContent = document.getElementById('advancedContent');
  advancedToggle?.addEventListener('click', () => {
    const open = advancedContent?.classList.toggle('open');
    advancedToggle.classList.toggle('open', !!open);
    advancedToggle.setAttribute('aria-expanded', String(!!open));
  });

  ['pronounToggle','verbToggle','vocabToggle'].forEach(id => {
    const el = document.getElementById(id);
    el?.addEventListener('click', () => {
      el.classList.toggle('active');
      el.setAttribute('aria-checked', String(el.classList.contains('active')));
    });
  });

  let swapped = false;
  document.getElementById('flipBtn')?.addEventListener('click', () => {
    swapped = !swapped;
    const inp = document.getElementById('input-text') as HTMLTextAreaElement;
    const out = document.getElementById('output-text') as HTMLTextAreaElement;
    const inLabel = document.getElementById('inLabel');
    const outLabel = document.getElementById('outLabel');
    if (inLabel) inLabel.textContent = swapped ? 'Old English' : 'Modern English';
    if (outLabel) outLabel.textContent = swapped ? 'Modern English' : 'Old English';
    inp.placeholder = swapped ? 'Enter Old English text here...' : 'Enter your modern text here...';
    out.placeholder = swapped ? 'Modern translation shalt appear...' : 'Thy translation shalt appear here...';
    const tmp = inp.value; inp.value = out.value; out.value = tmp;
    if (charCount) charCount.textContent = String(inp.value.length);
  });

  document.getElementById('clearBtn')?.addEventListener('click', () => {
    (document.getElementById('input-text') as HTMLTextAreaElement).value = '';
    (document.getElementById('output-text') as HTMLTextAreaElement).value = '';
    if (charCount) charCount.textContent = '0';
    const copyBtn = document.getElementById('copyBtn');
    if (copyBtn) copyBtn.style.opacity = '0';
  });

  document.getElementById('copyBtn')?.addEventListener('click', () => {
    const out = (document.getElementById('output-text') as HTMLTextAreaElement).value;
    navigator.clipboard.writeText(out);
    const btn = document.getElementById('copyBtn');
    if (btn) { btn.textContent = '✓ Copied'; setTimeout(() => { btn.textContent = '⎘ Copy'; }, 1600); }
  });

  document.querySelectorAll('.ex-card').forEach(card => {
    card.addEventListener('click', () => {
      const m = card.getAttribute('data-modern') || '';
      const o = card.getAttribute('data-old') || '';
      const inp = document.getElementById('input-text') as HTMLTextAreaElement;
      const out = document.getElementById('output-text') as HTMLTextAreaElement;
      if (inp) inp.value = m;
      if (out) out.value = o;
      if (charCount) charCount.textContent = String(m.length);
      const copyBtn = document.getElementById('copyBtn');
      if (copyBtn) copyBtn.style.opacity = '1';
    });
  });
</script>
</Layout>
