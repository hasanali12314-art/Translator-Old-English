---
import Layout from '../../layouts/Layout.astro';
import ToolPageLayout from '../../components/ToolPageLayout.astro';
import TranslatorTool from '../../components/TranslatorTool.astro';

const related = [
  { href: '/rare-languages/', name: 'Rare Languages' },
  { href: '/navajo-translator/', name: 'Navajo' },
  { href: '/dialect-translator/', name: 'Dialect Converter' },
];

const examples = [
  { inputLabel: 'English', outputLabel: 'Sinhala', input: 'Good morning, how are you?', output: 'සුබ උදෑසනක්, ඔබ කෙසේ ද?' },
  { inputLabel: 'English', outputLabel: 'Sinhala', input: 'Welcome to Sri Lanka.', output: 'ශ්‍රී ලංකාවට සාදරයෙන් පිළිගනිමු.' },
  { inputLabel: 'English', outputLabel: 'Sinhala', input: 'Thank you very much.', output: 'ඉතා ස්තූතිය.' },
];

const titleHtml = 'Sinhala <span class="gold-text">Translator</span>';

---
<Layout title="Sinhala Translator — English to Sinhala Free Online" description="Translate English to Sinhala or Sinhala to English instantly. Free AI-powered Sinhala translation with native script support." canonical="/sinhala-translator/">
  <ToolPageLayout
    breadcrumb={[
      { href: '/translator-old-english/', label: 'Home' },
      { href: '/specialty-translators/', label: 'Specialty Translators' },
      { label: 'Sinhala Translator' },
    ]}
    backLink={{ href: '/specialty-translators/', label: '← Back to Specialty Translators' }}
    titleHtml={titleHtml}
    heroSub="Translate English to Sinhala (සිංහල) or Sinhala to English — free, instant, AI-powered"
    examplesTitle="Translation Examples"
    examplesSub="Click any card to load it into the translator"
    examples={examples}
    related={related}
    relatedTitle="Related Tools"
    relatedBack={{ href: '/specialty-translators/', label: 'Back to Specialty Translators' }}
    ctaTitle='Translate to <span class="gold-text">Sinhala</span> Now'
    ctaSub="Free, instant, AI-powered Sinhala translation"
    ctaBtn="✦ Start Translating"
  >
    <TranslatorTool
      slot="tool"
      sourceLang="en"
      targetLang="si"
      inputLabel="English"
      outputLabel="Sinhala (සිංහල)"
      inputPlaceholder="Type or paste your English text here..."
      outputPlaceholder="ඔබේ සිංහල පරිවර්තනය මෙහි දිස්වේ..."
    />
    <div class="info-block">
      <h2>About <span class="gold-text">Sinhala</span></h2>
      <p>Sinhala (සිංහල) is an Indo-Aryan language spoken by approximately 17 million people, primarily in Sri Lanka where it is one of the official languages alongside Tamil. It has its own unique script derived from the ancient Brahmi alphabet and has been written for over 2,000 years. Return to <a href="/specialty-translators/">Specialty Translators</a>.</p>
    </div>
  </ToolPageLayout>
</Layout>
