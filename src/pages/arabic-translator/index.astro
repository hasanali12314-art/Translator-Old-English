---
import Layout from '../../layouts/Layout.astro';
import TranslatorTool from '../../components/TranslatorTool.astro';
---
<Layout title="Arabic Translator — English to Arabic Free Online" description="Translate English to Arabic or Arabic to English instantly. Free AI-powered Arabic translation supporting right-to-left text." canonical="/arabic-translator/">
<section class="hero-section"><div class="container">
  <nav class="breadcrumb" style="margin-bottom:16px;"><a href="/translator-old-english/">Home</a><span>›</span><a href="/language-translators/">Language Translators</a><span>›</span><span>Arabic Translator</span></nav>
  <a href="/language-translators/" class="btn btn-ghost btn-sm" style="margin-bottom:24px;">← Back to Language Translators</a>
  <h1 id="main-heading">Arabic <span class="gold-text">Translator</span></h1>
  <p class="hero-sub">Translate English to Arabic or Arabic to English — free, instant, AI-powered with RTL support</p>
</div></section>
<section class="section-sm"><div class="container"><TranslatorTool sourceLang="en" targetLang="ar" inputLabel="English" outputLabel="Arabic" inputPlaceholder="Type or paste your English text here..." outputPlaceholder="ستظهر ترجمتك العربية هنا..." /></div></section>
<section class="section-sm"><div class="container">
  <div class="section-heading"><h2>Translation <span class="gold-text">Examples</span></h2></div>
  <div class="grid-3">
    {[{e:'Hello, how are you?',a:'مرحبًا، كيف حالك؟'},{e:'Welcome to our country.',a:'أهلاً وسهلاً في بلدنا.'},{e:'The weather is pleasant today.',a:'الطقس لطيف اليوم.'}].map(ex=>(
      <div class="example-card"><div class="example-card-section"><div class="example-label">English</div><div class="example-text">{ex.e}</div></div><div class="example-card-section"><div class="example-label">Arabic</div><div class="example-text" style="color:var(--gold-light);direction:rtl;text-align:right;">{ex.a}</div></div></div>
    ))}
  </div>
</div></section>
<section class="section"><div class="container" style="max-width:800px;">
  <h2 style="margin-bottom:16px;">About <span class="gold-text">Arabic</span></h2>
  <p style="color:var(--text-secondary);line-height:1.8;margin-bottom:20px;">Arabic is spoken by over 400 million people across 22 countries in the Middle East and North Africa. It is one of the six official languages of the United Nations and the liturgical language of Islam. Modern Standard Arabic is used in formal writing and media, while numerous regional dialects are used in everyday speech.</p>
  <p style="color:var(--text-secondary);line-height:1.8;">This translator outputs Modern Standard Arabic, suitable for formal documents, academic work, and professional communication. For Egyptian dialect, see <a href="/egyptian-arabic/">Egyptian Arabic Translator</a>. Return to <a href="/language-translators/">Language Translators</a>.</p>
</div></section>
<section class="section-sm"><div class="container">
  <div class="section-heading"><h2>Related <span class="gold-text">Translators</span></h2></div>
  <div class="grid-4">
    {[{href:'/chinese-translator/',n:'Chinese'},{href:'/spanish-translator/',n:'Spanish'},{href:'/greek-translator/',n:'Greek'},{href:'/dialect-translator/',n:'Dialect Converter'}].map(r=>(<a href={r.href} class="card" style="text-decoration:none;text-align:center;font-weight:600;font-size:0.9rem;">{r.n}</a>))}
  </div>
  <div style="text-align:center;margin-top:24px;"><a href="/language-translators/" class="btn btn-outline">Browse all Language Translators</a></div>
</div></section>
<section class="section"><div class="container" style="max-width:800px;">
  <div class="section-heading"><h2>Frequently Asked <span class="gold-text">Questions</span></h2></div>
  {[{q:'Is it Modern Standard Arabic or a dialect?',a:'This translator outputs Modern Standard Arabic (MSA), the formal written form used across all Arabic-speaking countries.'},{q:'Does it support right-to-left text display?',a:'Yes. Arabic output is displayed right-to-left as per the natural Arabic script direction.'},{q:'Can I translate Arabic back to English?',a:'Yes. Use the flip button to reverse translation direction.'},{q:'Is this tool free to use?',a:'Completely free, no account required.'},{q:'What is the character limit?',a:'Up to 5,000 characters per translation.'},{q:'How accurate is the Arabic translation?',a:'Very accurate for MSA. Regional dialect nuances may vary.'},{q:'Does it work on mobile?',a:'Yes, fully responsive on all devices.'},{q:'Can I use translations commercially?',a:'Yes. All output is free for personal and commercial use.'}].map(f=>(<div class="faq-item"><button class="faq-question">{f.q}<span class="faq-icon">+</span></button><div class="faq-answer">{f.a}</div></div>))}
</div></section>
<section class="section-sm"><div class="container"><div class="cta-banner">
  <h2 style="margin-bottom:16px;">Translate to <span class="gold-text">Arabic</span> Now</h2>
  <a href="#tool-area" class="btn btn-primary btn-lg" style="margin-bottom:32px;">✦ Start Translating</a>
  <div class="trust-badges"><div class="trust-badge"><div class="trust-badge-icon">🆓</div> Free forever</div><div class="trust-badge"><div class="trust-badge-icon">⚡</div> Instant results</div><div class="trust-badge"><div class="trust-badge-icon">🤖</div> AI-powered accuracy</div></div>
</div></div></section>
</Layout>
