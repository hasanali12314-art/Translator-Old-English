---
import Layout from '../../layouts/Layout.astro';
import ToolPageLayout from '../../components/ToolPageLayout.astro';
import TranslatorTool from '../../components/TranslatorTool.astro';

const related = [
  { href: '/chinese-translator/', name: 'Chinese Translator' },
  { href: '/spanish-translator/', name: 'Spanish Translator' },
  { href: '/greek-translator/', name: 'Greek Translator' },
  { href: '/dialect-translator/', name: 'Dialect Converter' },
];

const examples = [
  { inputLabel: 'English', outputLabel: 'Arabic', input: 'Hello, how are you?', output: 'مرحبًا، كيف حالك؟' },
  { inputLabel: 'English', outputLabel: 'Arabic', input: 'Welcome to our country.', output: 'أهلاً وسهلاً في بلدنا.' },
  { inputLabel: 'English', outputLabel: 'Arabic', input: 'The weather is pleasant today.', output: 'الطقس لطيف اليوم.' },
];

const titleHtml = 'Arabic <span class="gold-text">Translator</span>';

---
<Layout title="Arabic Translator — English to Arabic Free Online" description="Translate English to Arabic or Arabic to English instantly. Free AI-powered Arabic translation supporting right-to-left text." canonical="/arabic-translator/">
  <ToolPageLayout
    breadcrumb={[
      { href: '/', label: 'Home' },
      { href: '/language-translators/', label: 'Language Translators' },
      { label: 'Arabic Translator' },
    ]}
    backLink={{ href: '/language-translators/', label: '← Back to Language Translators' }}
    titleHtml={titleHtml}
    toolLabel="Arabic"
    heroSub="Translate English to Arabic or Arabic to English — free, instant, AI-powered with RTL support"
    examplesSub="Click any card to load it into the translator"
    examples={examples}
    related={related}
    relatedBack={{ href: '/language-translators/', label: 'Browse all Language Translators' }}
    ctaTitle='Translate to <span class="gold-text">Arabic</span> Now'
    ctaSub="Free, instant, AI-powered Arabic translation"
    ctaBtn="✦ Start Translating"
  >
    <TranslatorTool
      slot="tool"
      sourceLang="en"
      targetLang="ar"
      inputLabel="English"
      outputLabel="Arabic"
      inputPlaceholder="Type or paste your English text here..."
      outputPlaceholder="ستظهر ترجمتك العربية هنا..."
    />
    <div class="info-block">
      <h3>About <span class="gold-text">Arabic</span></h3>
      <p>Arabic is spoken by over 400 million people across 22 countries in the Middle East and North Africa. It is one of the six official languages of the United Nations and the liturgical language of Islam. Modern Standard Arabic is used in formal writing and media, while numerous regional dialects are used in everyday speech.</p>
      <p>This translator outputs Modern Standard Arabic, suitable for formal documents, academic work, and professional communication. For Egyptian dialect, see <a href="/egyptian-arabic/">Egyptian Arabic Translator</a>. Return to <a href="/language-translators/">Language Translators</a>.</p>
    </div>
  </ToolPageLayout>
</Layout>
