---
import Layout from '../../layouts/Layout.astro';
import ToolPageLayout from '../../components/ToolPageLayout.astro';
import TranslatorTool from '../../components/TranslatorTool.astro';

const related = [
  { href: '/french-translator/', name: 'French Translator' },
  { href: '/spanish-translator/', name: 'Spanish Translator' },
  { href: '/rare-languages/', name: 'Rare Languages' },
];

const examples = [
  { inputLabel: 'English', outputLabel: 'Creole (Haitian)', input: 'Good morning, how are you?', output: 'Bonjou, kijan ou ye?' },
  { inputLabel: 'English', outputLabel: 'Creole (Haitian)', input: 'Where can I find help?', output: 'Kote mwen ka jwenn èd?' },
  { inputLabel: 'English', outputLabel: 'Creole (Haitian)', input: 'Thank you for your kindness.', output: 'Mèsi pou jantiyès ou.' },
];

const titleHtml = 'Creole <span class="gold-text">Translator</span>';

---
<Layout title="Creole Translator — English to Haitian Creole Free Online" description="Translate English to Haitian Creole or Creole to English instantly. Free AI-powered Creole translation tool." canonical="/creole-translator/">
  <ToolPageLayout
    breadcrumb={[
      { href: '/translator-old-english/', label: 'Home' },
      { href: '/language-translators/', label: 'Language Translators' },
      { label: 'Creole Translator' },
    ]}
    backLink={{ href: '/language-translators/', label: '← Back to Language Translators' }}
    titleHtml={titleHtml}
    heroSub="Translate English to Haitian Creole (Kreyòl Ayisyen) or Creole to English — free, instant, AI-powered"
    examplesTitle="Translation Examples"
    examplesSub="Click any card to load it into the translator"
    examples={examples}
    related={related}
    relatedBack={{ href: '/language-translators/', label: 'Browse all Language Translators' }}
    ctaTitle='Translate to <span class="gold-text">Creole</span> Now'
    ctaSub="Free, instant, AI-powered Creole translation"
    ctaBtn="✦ Start Translating"
  >
    <TranslatorTool
      slot="tool"
      sourceLang="en"
      targetLang="ht"
      inputLabel="English"
      outputLabel="Creole (Haitian)"
      inputPlaceholder="Type or paste your English text here..."
      outputPlaceholder="Tradiksyon Kreyòl ou a pral parèt la..."
    />
    <div class="info-block">
      <h2>About <span class="gold-text">Haitian Creole</span></h2>
      <p>Haitian Creole (Kreyòl Ayisyen) is spoken by approximately 12 million people, primarily in Haiti where it is one of the two official languages alongside French. It developed from French during the colonial period, blending French vocabulary with West African grammar and influences from Spanish, English, Portuguese, and Taíno.</p>
      <p>This translator is valuable for humanitarian work, healthcare communication, travel to Haiti, and cultural research. Return to <a href="/language-translators/">Language Translators</a>.</p>
    </div>
  </ToolPageLayout>
</Layout>
