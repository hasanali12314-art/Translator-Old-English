---
import Layout from '../../layouts/Layout.astro';
---
<Layout
  title="Contact Us — Translator Old English"
  description="Contact Translator Old English for support, feedback, and partnership enquiries."
  canonical="/contact-us/"
>
<section class="hero-section"><div class="container">
  <h1 id="main-heading">Contact <span class="gold-text">Us</span></h1>
  <p class="hero-sub">Questions, feedback, or partnership — we would love to hear from you</p>
</div></section>
<section class="section"><div class="container" style="max-width:720px">
  <div class="info-block">
    <h2>Get in touch</h2>
    <p style="color:var(--ink2);line-height:1.8;margin-bottom:20px">
      For general enquiries about our Old English translator, technical issues, or suggestions to improve the site, use the email below. We aim to reply within 48 hours on business days.
    </p>
    <p style="color:var(--ink2);line-height:1.8;margin-bottom:28px">
      <strong>Email:</strong>
      <a href="mailto:support@translatoroldenglish.com">support@translatoroldenglish.com</a>
    </p>
    <p style="color:var(--muted);font-size:var(--fs-label);line-height:1.7">
      Please do not send sensitive personal data by email. For privacy matters, see our
      <a href="/privacy-policy/">Privacy Policy</a>.
    </p>
  </div>
  <div style="display:flex;gap:16px;flex-wrap:wrap;margin-top:24px">
    <a href="/about-us/" class="btn btn-ghost">About Us</a>
    <a href="/" class="btn btn-primary">Back to Translator</a>
  </div>
</div></section>
</Layout>
