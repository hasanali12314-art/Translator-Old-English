---
import Layout from '../../layouts/Layout.astro';
import PageSeoSections from '../../components/PageSeoSections.astro';
import { PAGE_SEO_CONTENT } from '../../data/pageSeoContent';
const featured = [
  {href:'/chinese-translator/',name:'Chinese Translator',vol:'246k/mo',kw:'62 keywords'},
  {href:'/spanish-translator/',name:'Spanish Translator',vol:'High volume',kw:'59 keywords'},
  {href:'/arabic-translator/',name:'Arabic Translator',vol:'High volume',kw:'37 keywords'},
];
const all = [
  {href:'/chinese-translator/',name:'Chinese Translator',kw:'62 keywords',vol:'246k/mo'},
  {href:'/greek-translator/',name:'Greek Translator',kw:'56 keywords',vol:'90k/mo'},
  {href:'/arabic-translator/',name:'Arabic Translator',kw:'37 keywords',vol:'High volume'},
  {href:'/spanish-translator/',name:'Spanish Translator',kw:'59 keywords',vol:'High volume'},
  {href:'/german-translator/',name:'German Translator',kw:'20 keywords',vol:''},
  {href:'/french-translator/',name:'French Translator',kw:'12 keywords',vol:''},
  {href:'/creole-translator/',name:'Creole Translator',kw:'32 keywords',vol:''},
];
---
<Layout title="Language Translators — Free Online for All" description="Browse all language translator pages. Chinese, Spanish, Arabic, Greek, French, German, Creole and more — free, AI-powered." canonical="/language-translators/">
<section class="hero-section"><div class="container">
  <h1 id="main-heading">Language <span class="gold-text">Translators</span></h1>
  <p class="hero-sub">Free AI-powered translation for the world's most-spoken languages — instant, accurate, no account needed</p>
</div></section>

<section class="section-sm"><div class="container">
  <div class="section-heading"><h2>Featured <span class="gold-text">Languages</span></h2></div>
  <div class="grid-3">
    {featured.map(f=>(
      <a href={f.href} class="card card-gold" style="text-decoration:none;display:block">
        <div class="badge badge-gold" style="margin-bottom:12px">{f.vol}</div>
        <h3 style="margin-bottom:6px">{f.name}</h3>
        <p style="color:var(--text-muted)">{f.kw}</p>
        <div style="color:var(--gold);margin-top:16px;font-weight:600">Translate Now →</div>
      </a>
    ))}
  </div>
</div></section>

<section class="section"><div class="container">
  <div class="section-heading"><h2>All <span class="gold-text">Language Pages</span></h2></div>
  <div class="grid-3">
    {all.map(l=>(
      <a href={l.href} class="card" style="text-decoration:none;display:block">
        <h3 style="margin-bottom:8px">{l.name}</h3>
        <div style="display:flex;gap:12px;flex-wrap:wrap">
          <span class="badge badge-gold">{l.kw}</span>
          {l.vol && <span style="color:var(--text-muted);display:flex;align-items:center">{l.vol}</span>}
        </div>
        <div style="color:var(--gold);margin-top:14px;font-weight:600">{l.href} →</div>
      </a>
    ))}
  </div>
</div></section>

<section class="section-sm"><div class="container" style="max-width:800px">
  <PageSeoSections {...PAGE_SEO_CONTENT['language-translators']} />
  <p style="color:var(--text-secondary);line-height:1.8;margin-top:8px"><a href="/">Return to the homepage</a> for the Old English translator.</p>
</div></section>
</Layout>
