---
import Layout from '../../layouts/Layout.astro';
import ToolPageLayout from '../../components/ToolPageLayout.astro';
import TranslatorTool from '../../components/TranslatorTool.astro';

const related = [
  { href: '/dialect-translator/', name: 'Dialect Converter' },
  { href: '/fancy-translator/', name: 'Fancy Text' },
  { href: '/', name: 'Main Tool' },
];

const examples = [
  { inputLabel: 'Spoken Input', outputLabel: 'Translated Output', input: "Hey, what's up? You coming later?", output: 'Hola, ¿qué tal? ¿Vendrás más tarde?' },
  { inputLabel: 'Spoken Input', outputLabel: 'Translated Output', input: 'Catch you on the flip side, mate.', output: "À tout à l'heure, mon ami." },
  { inputLabel: 'Spoken Input', outputLabel: 'Translated Output', input: 'That was absolutely brilliant, well done!', output: 'Das war absolut brillant, gut gemacht!' },
];

const titleHtml = 'Speak <span class="gold-text">Translator</span>';

---
<Layout title="Speak Translator — Voice & Spoken Language Translation Free" description="Translate spoken and typed text with our free speak translator tool. Voice-friendly, instant, AI-powered translation." canonical="/speak-translate/">
  <ToolPageLayout
    breadcrumb={[
      { href: '/', label: 'Home' },
      { href: '/specialty-translators/', label: 'Specialty Translators' },
      { label: 'Speak Translator' },
    ]}
    backLink={{ href: '/specialty-translators/', label: '← Back to Specialty Translators' }}
    titleHtml={titleHtml}
    heroSub="Translate spoken or typed text instantly — voice-friendly, free, AI-powered translation"
    examplesTitle="Conversion Examples"
    examplesSub="Click any card to load it into the translator"
    examples={examples}
    related={related}
    relatedTitle="Related Tools"
    relatedBack={{ href: '/specialty-translators/', label: 'Back to Specialty Translators' }}
    ctaTitle='Start <span class="gold-text">Speaking & Translating</span>'
    ctaSub="Free, instant conversational translation"
    ctaBtn="✦ Translate Now"
  >
    <TranslatorTool
      slot="tool"
      sourceLang="en"
      targetLang="es"
      inputLabel="Spoken or Typed Input"
      outputLabel="Translated Output"
      inputPlaceholder="Type your spoken or conversational text here..."
      outputPlaceholder="Your translated output will appear here..."
    />
    <div class="info-block">
      <h2>About <span class="gold-text">Speak Translation</span></h2>
      <p>The Speak Translator is optimised for conversational and spoken language patterns. Unlike formal translators, it handles contractions, colloquialisms, informal grammar, and natural speech rhythms — delivering translations that sound natural when spoken aloud. Return to <a href="/specialty-translators/">Specialty Translators</a>.</p>
    </div>
  </ToolPageLayout>
</Layout>
