---
import Layout from '../../layouts/Layout.astro';
import ToolPageLayout from '../../components/ToolPageLayout.astro';
import TranslatorTool from '../../components/TranslatorTool.astro';

const related = [
  { href: '/spanish-translator/', name: 'Spanish Translator' },
  { href: '/german-translator/', name: 'German Translator' },
  { href: '/creole-translator/', name: 'Creole Translator' },
];

const examples = [
  { inputLabel: 'English', outputLabel: 'French', input: 'Excuse me, where is the museum?', output: 'Excusez-moi, où est le musée?' },
  { inputLabel: 'English', outputLabel: 'French', input: 'I would like a table for two.', output: 'Je voudrais une table pour deux.' },
  { inputLabel: 'English', outputLabel: 'French', input: 'The food here is extraordinary.', output: 'La nourriture ici est extraordinaire.' },
];

const titleHtml = 'French <span class="gold-text">Translator</span>';

---
<Layout title="French Translator — English to French Free Online" description="Translate English to French or French to English instantly. Free AI-powered French translation with accented character support." canonical="/french-translator/">
  <ToolPageLayout
    breadcrumb={[
      { href: '/translator-old-english/', label: 'Home' },
      { href: '/language-translators/', label: 'Language Translators' },
      { label: 'French Translator' },
    ]}
    backLink={{ href: '/language-translators/', label: '← Back to Language Translators' }}
    titleHtml={titleHtml}
    heroSub="Translate English to French or French to English — European &amp; Canadian French, free and instant"
    examplesTitle="Translation Examples"
    examplesSub="Click any card to load it into the translator"
    examples={examples}
    related={related}
    relatedBack={{ href: '/language-translators/', label: 'Browse all Language Translators' }}
    ctaTitle='Translate to <span class="gold-text">French</span> Now'
    ctaSub="Free, instant, AI-powered French translation"
    ctaBtn="✦ Start Translating"
  >
    <TranslatorTool
      slot="tool"
      sourceLang="en"
      targetLang="fr"
      inputLabel="English"
      outputLabel="French"
      inputPlaceholder="Type or paste your English text here..."
      outputPlaceholder="Votre traduction française apparaîtra ici..."
    />
    <div class="info-block">
      <h2>About <span class="gold-text">French</span></h2>
      <p>French is spoken by over 300 million people across France, Belgium, Switzerland, Canada, and many African nations. It is one of the six official languages of the United Nations and the language of diplomacy, cuisine, fashion, and art. French uses accented characters (é, è, ê, à, ù, ç) which this translator handles correctly.</p>
      <p>This tool is ideal for travel to France and Francophone countries, academic writing, business correspondence, and language learning. Return to <a href="/language-translators/">Language Translators</a>.</p>
    </div>
  </ToolPageLayout>
</Layout>
