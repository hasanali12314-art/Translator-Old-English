---
import Layout from '../../layouts/Layout.astro';
import PageSeoSections from '../../components/PageSeoSections.astro';
import { PAGE_SEO_CONTENT } from '../../data/pageSeoContent';
const sections=[
  {href:'/translation-tools/',icon:'🔧',name:'Translation Tools',desc:'Overview of all translation tools available on the site — 17 targeted keywords'},
  {href:'/blog/',icon:'📖',name:'Blog',desc:'Articles on Old English history, grammar, translation tips, and linguistics'},
];
---
<Layout title="Translation Tools & Resources — Free Guides" description="Browse all translation tools and resources including tool overviews and blog articles. Free and AI-powered." canonical="/tools-resources/">
<section class="hero-section"><div class="container">
  <h1 id="main-heading">Tools & <span class="gold-text">Resources</span></h1>
  <p class="hero-sub">Everything you need to get the most from free AI-powered translation</p>
</div></section>
<section class="section-sm"><div class="container" style="max-width:800px">
  <p style="color:var(--text-secondary);line-height:1.8;margin-bottom:16px">
    This hub connects the full translation-tools directory with the blog, where we publish long-form guides on Old English grammar, Shakespearean language, Norse influence, and practical writing tips. Bookmark it when you need an overview before opening a specific language or ancient-language page.
  </p>
  <p style="color:var(--text-secondary);line-height:1.8">
    Students often start with blog articles on grammar basics, then practise on the homepage translator. Game developers and fantasy authors combine vocabulary posts with Anglo-Saxon style output. Teachers can link directly to the translation-tools list when assigning compare-and-contrast homework across modern and historical English.
  </p>
</div></section>
<section class="section"><div class="container">
  <div class="section-heading"><h2>Available <span class="gold-text">Resources</span></h2></div>
  <div class="grid-3">
    {sections.map(s=>(<a href={s.href} class="card card-gold" style="text-decoration:none;display:block">
      <div style="margin-bottom:12px">{s.icon}</div>
      <h3 style="margin-bottom:8px">{s.name}</h3>
      <p style="color:var(--text-secondary)">{s.desc}</p>
      <div style="color:var(--gold);margin-top:14px;font-weight:600">Explore →</div>
    </a>))}
  </div>
</div></section>
<section class="section-sm"><div class="container" style="max-width:800px">
  <PageSeoSections {...PAGE_SEO_CONTENT['tools-resources']} />
  <p style="color:var(--text-secondary);line-height:1.8;margin-top:8px"><a href="/">Return to the homepage</a>.</p>
</div></section>
</Layout>
