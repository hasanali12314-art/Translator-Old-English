---
import Layout from '../../layouts/Layout.astro';
import PageSeoSections from '../../components/PageSeoSections.astro';
import { PAGE_SEO_CONTENT } from '../../data/pageSeoContent';
const pages = [
  {href:'/latin-translator/',name:'Latin Translator',note:'21 keywords',icon:'🏛️',desc:'Classical and Ecclesiastical Latin'},
  {href:'/old-english/',name:'Anglo-Saxon Old English',note:'Old English & Norse',icon:'⚔️',desc:'Anglo-Saxon and Old Norse'},
  {href:'/aramaic-translator/',name:'Aramaic Translator',note:'Aramaic & Coptic',icon:'📜',desc:'Biblical Aramaic and Coptic'},
  {href:'/egyptian-arabic/',name:'Egyptian Arabic Translator',note:'27 keywords',icon:'🏺',desc:'Egyptian dialect and hieroglyphic context'},
  {href:'/ancient-greek/',name:'Ancient Greek Translator',note:'Koine & Classical',icon:'🏺',desc:'Koine and Classical Ancient Greek'},
];
---
<Layout title="Ancient Languages Translator — Latin & Greek" description="Translate to and from ancient languages: Latin, Old English, Ancient Greek, Aramaic, Coptic, and Egyptian Arabic. Free AI-powered ancient language tools." canonical="/ancient-languages/">
<section class="hero-section"><div class="container">
  <h1 id="main-heading">Ancient <span class="gold-text">Languages</span></h1>
  <p class="hero-sub">Explore the languages of history — Latin, Old English, Ancient Greek, Aramaic, Coptic, and Egyptian Arabic</p>
</div></section>
<section class="section-sm"><div class="container" style="max-width:800px">
  <p style="color:var(--text-secondary);line-height:1.8">
    These tools focus on classical and historical registers — Latin for liturgy and literature, Koine and classical Greek, Anglo-Saxon Old English, biblical Aramaic, and Egyptian Arabic for regional study. Use complete sentences for best results and verify sensitive religious or academic text with a qualified scholar.
  </p>
</div></section>
<section class="section"><div class="container">
  <div class="section-heading"><h2>Ancient Language <span class="gold-text">Translators</span></h2></div>
  <div class="grid-3">
    {pages.map(p=>(
      <a href={p.href} class="card card-gold" style="text-decoration:none;display:block">
        <div style="margin-bottom:12px">{p.icon}</div>
        <h3 style="margin-bottom:6px">{p.name}</h3>
        <div class="badge badge-gold" style="margin-bottom:10px">{p.note}</div>
        <p style="color:var(--text-secondary)">{p.desc}</p>
        <div style="color:var(--gold);margin-top:14px;font-weight:600">Translate Now →</div>
      </a>
    ))}
  </div>
</div></section>
<section class="section-sm"><div class="container" style="max-width:800px">
  <PageSeoSections {...PAGE_SEO_CONTENT['ancient-languages']} />
  <p style="color:var(--text-secondary);line-height:1.8;margin-top:8px"><a href="/">Return to the homepage</a>.</p>
</div></section>
</Layout>
