---
import Layout from '../../layouts/Layout.astro';
import ToolPageLayout from '../../components/ToolPageLayout.astro';
import TranslatorTool from '../../components/TranslatorTool.astro';

const related = [
  { href: '/aramaic-translator/', name: 'Aramaic' },
  { href: '/dialect-translator/', name: 'Dialect Converter' },
  { href: '/rare-languages/', name: 'Rare Languages' },
];

const examples = [
  { inputLabel: 'Modern English', outputLabel: 'Egyptian Arabic', input: 'Good morning, how are you?', output: 'صباح الخير، إزيك؟' },
  { inputLabel: 'Modern English', outputLabel: 'Egyptian Arabic', input: 'Where is the Nile?', output: 'فين النيل؟' },
  { inputLabel: 'Modern English', outputLabel: 'Egyptian Arabic', input: 'I love Egypt very much.', output: 'أنا بحب مصر أوي.' },
];

const titleHtml = 'Egyptian Arabic <span class="gold-text">Translator</span>';

---
<Layout title="Egyptian Arabic Translator — English to Egyptian Arabic Free" description="Translate English to Egyptian Arabic dialect or Egyptian Arabic to English. Free AI-powered translation tool." canonical="/egyptian-arabic/">
  <ToolPageLayout
    breadcrumb={[
      { href: '/', label: 'Home' },
      { href: '/ancient-languages/', label: 'Ancient Languages' },
      { label: 'Egyptian Arabic Translator' },
    ]}
    backLink={{ href: '/ancient-languages/', label: '← Back to Ancient Languages' }}
    titleHtml={titleHtml}
    toolLabel="Egyptian Arabic"
    heroSub="Translate English to Egyptian Arabic dialect or Egyptian Arabic to English — free, instant, AI-powered"
    examplesSub="Click any card to load it into the translator"
    examples={examples}
    related={related}
    relatedTitle="Related Pages"
    ctaTitle='Translate to <span class="gold-text">Egyptian Arabic</span> Now'
    ctaSub="Free, instant, AI-powered Egyptian Arabic translation"
    ctaBtn="✦ Start Translating"
  >
    <TranslatorTool
      slot="tool"
      sourceLang="en"
      targetLang="ar"
      inputLabel="Modern English"
      outputLabel="Egyptian Arabic"
      inputPlaceholder="Type or paste your modern English text here..."
      outputPlaceholder="الترجمة المصرية العامية ستظهر هنا..."
      showStyleDropdown={true}
      showAdvanced={true}
    />
    <div class="info-block">
      <h3>About <span class="gold-text">Egyptian Arabic</span></h3>
      <p>Egyptian Arabic (Masri/Aamiyya) is spoken by over 100 million people and is the most widely understood Arabic dialect in the world, largely due to Egypt's influence in film, music, and television across the Arab world. It differs significantly from Modern Standard Arabic in pronunciation, vocabulary, and grammar.</p>
      <p>This translator is ideal for travel to Egypt, media research, and connecting with Egyptian communities. For Modern Standard Arabic, visit the <a href="/arabic-translator/">Arabic Translator</a>. Return to <a href="/ancient-languages/">Ancient Languages</a>.</p>
    </div>
  </ToolPageLayout>
</Layout>
