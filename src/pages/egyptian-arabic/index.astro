---
import Layout from '../../layouts/Layout.astro';
import TranslatorTool from '../../components/TranslatorTool.astro';
---
<Layout title="Egyptian Arabic Translator — English to Egyptian Arabic Free" description="Translate English to Egyptian Arabic dialect or Egyptian Arabic to English. Free AI-powered translation tool." canonical="/egyptian-arabic/">
<section class="hero-section"><div class="container">
  <nav class="breadcrumb" style="margin-bottom:16px"><a href="/translator-old-english/">Home</a><span>›</span><a href="/ancient-languages/">Ancient Languages</a><span>›</span><span>Egyptian Arabic Translator</span></nav>
  <a href="/ancient-languages/" class="btn btn-ghost btn-sm" style="margin-bottom:24px">← Back to Ancient Languages</a>
  <h1 id="main-heading">Egyptian Arabic <span class="gold-text">Translator</span></h1>
  <p class="hero-sub">Translate English to Egyptian Arabic dialect or Egyptian Arabic to English — free, instant, AI-powered</p>
</div></section>
<section class="section-sm"><div class="container"><TranslatorTool sourceLang="en" targetLang="ar" inputLabel="Modern English" outputLabel="Egyptian Arabic" inputPlaceholder="Type or paste your modern English text here..." outputPlaceholder="الترجمة المصرية العامية ستظهر هنا..." showStyleDropdown={true} showAdvanced={true} /></div></section>
<section class="section-sm"><div class="container">
  <div class="section-heading"><h2>Translation <span class="gold-text">Examples</span></h2></div>
  <div class="grid-3">
    {[{e:'Good morning, how are you?',ea:'صباح الخير، إزيك؟'},{e:'Where is the Nile?',ea:'فين النيل؟'},{e:'I love Egypt very much.',ea:'أنا بحب مصر أوي.'}].map(ex=>(
      <div class="example-card"><div class="example-card-section"><div class="example-label">Modern English</div><div class="example-text">{ex.e}</div></div><div class="example-card-section"><div class="example-label">Egyptian Arabic</div><div class="example-text" style="color:var(--gold-light);direction:rtl;text-align:right">{ex.ea}</div></div></div>
    ))}
  </div>
</div></section>
<section class="section"><div class="container" style="max-width:800px">
  <h2 style="margin-bottom:16px">About <span class="gold-text">Egyptian Arabic</span></h2>
  <p style="color:var(--text-secondary);line-height:1.8;margin-bottom:20px">Egyptian Arabic (Masri/Aamiyya) is spoken by over 100 million people and is the most widely understood Arabic dialect in the world, largely due to Egypt's influence in film, music, and television across the Arab world. It differs significantly from Modern Standard Arabic in pronunciation, vocabulary, and grammar.</p>
  <p style="color:var(--text-secondary);line-height:1.8">This translator is ideal for travel to Egypt, media research, and connecting with Egyptian communities. For Modern Standard Arabic, visit the <a href="/arabic-translator/">Arabic Translator</a>. Return to <a href="/ancient-languages/">Ancient Languages</a>.</p>
</div></section>
<section class="section-sm"><div class="container">
  <div class="section-heading"><h2>Related <span class="gold-text">Pages</span></h2></div>
  <div class="grid-3">{[{href:'/aramaic-translator/',n:'Aramaic'},{href:'/dialect-translator/',n:'Dialect Converter'},{href:'/rare-languages/',n:'Rare Languages'}].map(r=>(<a href={r.href} class="card" style="text-decoration:none;text-align:center;font-weight:600">{r.n}</a>))}</div>
</div></section>
<section class="section"><div class="container" style="max-width:800px">
  <div class="section-heading"><h2>Frequently Asked <span class="gold-text">Questions</span></h2></div>
  {[{q:'Is Egyptian Arabic a dialect or Modern Standard Arabic?',a:'It is a dialect — specifically the Egyptian colloquial Arabic (Masri) used in everyday speech, which differs significantly from Modern Standard Arabic.'},{q:'Can I translate both ways?',a:'Yes. Use the flip button to reverse the translation direction.'},{q:'Is this tool free to use?',a:'Completely free, no account required.'},{q:'What is the character limit?',a:'Up to 5,000 characters per translation.'},{q:'How accurate is the Egyptian Arabic translation?',a:'Good accuracy for common expressions. Dialectal nuances can vary by region within Egypt.'},{q:'How is it different from standard Arabic?',a:'Egyptian Arabic has different pronunciation, simplified grammar, and many vocabulary differences from Modern Standard Arabic. It is not mutually intelligible in written form.'},{q:'Does it work on mobile?',a:'Yes, fully responsive on all devices.'},{q:'Can I use translations commercially?',a:'Yes. All output is free for personal and commercial use.'}].map(f=>(<div class="faq-item"><button class="faq-question">{f.q}<span class="faq-icon">+</span></button><div class="faq-answer">{f.a}</div></div>))}
</div></section>
<section class="section-sm"><div class="container"><div class="cta-banner">
  <h2 style="margin-bottom:16px">Translate to <span class="gold-text">Egyptian Arabic</span> Now</h2>
  <a href="#tool-area" class="btn btn-primary btn-lg" style="margin-bottom:32px">✦ Start Translating</a>
  <div class="trust-badges"><div class="trust-badge"><div class="trust-badge-icon">🆓</div> Free forever</div><div class="trust-badge"><div class="trust-badge-icon">⚡</div> Instant results</div><div class="trust-badge"><div class="trust-badge-icon">🤖</div> AI-powered accuracy</div></div>
</div></div></section>
</Layout>
