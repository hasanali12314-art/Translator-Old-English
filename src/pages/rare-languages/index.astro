---
import Layout from '../../layouts/Layout.astro';
import ToolPageLayout from '../../components/ToolPageLayout.astro';
import TranslatorTool from '../../components/TranslatorTool.astro';

const related = [
  { href: '/sinhala-translator/', name: 'Sinhala' },
  { href: '/navajo-translator/', name: 'Navajo' },
  { href: '/dialect-translator/', name: 'Dialect' },
  { href: '/aramaic-translator/', name: 'Aramaic' },
];

const examples = [
  { inputLabel: 'English', outputLabel: 'Rare Language Output', input: 'Hello, how are you?', output: "Kwe kwe, ta'n tel-ula'luktinen? (Mi'kmaq)" },
  { inputLabel: 'English', outputLabel: 'Rare Language Output', input: 'The sun rises in the east.', output: 'Taiyo wa higashi kara noboru. (Ryukyuan)' },
  { inputLabel: 'English', outputLabel: 'Rare Language Output', input: 'Thank you for your help.', output: 'Faleminderit për ndihmën tënde. (Aromanian)' },
];

const titleHtml = 'Rare Language <span class="gold-text">Converter</span>';

---
<Layout title="Rare Language Converter — Minority & Endangered Language Translator Free" description="Translate to and from rare, minority, and endangered languages. Free AI-powered rare language converter online." canonical="/rare-languages/">
  <ToolPageLayout
    breadcrumb={[
      { href: '/translator-old-english/', label: 'Home' },
      { href: '/specialty-translators/', label: 'Specialty Translators' },
      { label: 'Rare Language Converter' },
    ]}
    backLink={{ href: '/specialty-translators/', label: '← Back to Specialty Translators' }}
    titleHtml={titleHtml}
    heroSub="Translate to minority, endangered, and rare languages — free, AI-powered, preserving linguistic diversity"
    examplesTitle="Conversion Examples"
    examplesSub="Click any card to load it into the translator"
    examples={examples}
    related={related}
    relatedTitle="Related Tools"
    relatedBack={{ href: '/specialty-translators/', label: 'Back to Specialty Translators' }}
    ctaTitle='Explore <span class="gold-text">Rare Languages</span>'
    ctaSub="Free, instant minority language translation"
    ctaBtn="✦ Start Converting"
  >
    <TranslatorTool
      slot="tool"
      sourceLang="en"
      targetLang="sw"
      inputLabel="English"
      outputLabel="Rare / Minority Language"
      inputPlaceholder="Type or paste your English text here..."
      outputPlaceholder="Your rare language translation will appear here..."
    />
    <div class="info-block">
      <h2>About <span class="gold-text">Rare Languages</span></h2>
      <p>The Rare Language Converter provides access to minority, endangered, and lesser-known languages that are underrepresented in standard translation tools. These include indigenous languages, regional languages, and languages with fewer than a million speakers. Preserving access to these languages helps maintain cultural heritage and linguistic diversity. Return to <a href="/specialty-translators/">Specialty Translators</a>.</p>
    </div>
  </ToolPageLayout>
</Layout>
