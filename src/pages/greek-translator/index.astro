---
import Layout from '../../layouts/Layout.astro';
import ToolPageLayout from '../../components/ToolPageLayout.astro';
import TranslatorTool from '../../components/TranslatorTool.astro';

const related = [
  { href: '/chinese-translator/', name: 'Chinese Translator' },
  { href: '/arabic-translator/', name: 'Arabic Translator' },
  { href: '/spanish-translator/', name: 'Spanish Translator' },
  { href: '/ancient-greek/', name: 'Ancient Greek' },
];

const examples = [
  { inputLabel: 'English', outputLabel: 'Greek', input: 'Good morning, how are you?', output: 'Καλημέρα, πώς είστε;' },
  { inputLabel: 'English', outputLabel: 'Greek', input: 'The sea is beautiful today.', output: 'Η θάλασσα είναι όμορφη σήμερα.' },
  { inputLabel: 'English', outputLabel: 'Greek', input: 'I would like a coffee, please.', output: 'Θα ήθελα έναν καφέ, παρακαλώ.' },
];

const titleHtml = 'Greek <span class="gold-text">Translator</span>';

---
<Layout title="Greek Translator — English to Greek Free Online" description="Translate English to Greek or Greek to English instantly. Free AI-powered Greek translation, no account needed." canonical="/greek-translator/">
  <ToolPageLayout
    breadcrumb={[
      { href: '/', label: 'Home' },
      { href: '/language-translators/', label: 'Language Translators' },
      { label: 'Greek Translator' },
    ]}
    backLink={{ href: '/language-translators/', label: '← Back to Language Translators' }}
    titleHtml={titleHtml}
    toolLabel="Greek"
    heroSub="Translate English to Modern Greek or Greek to English — free, instant, AI-powered"
    examplesSub="Click any card to load it into the translator"
    examples={examples}
    related={related}
    relatedBack={{ href: '/language-translators/', label: 'Browse all Language Translators' }}
    ctaTitle='Translate to <span class="gold-text">Greek</span> Now'
    ctaSub="Free, instant, AI-powered Greek translation"
    ctaBtn="✦ Start Translating"
  >
    <TranslatorTool
      slot="tool"
      sourceLang="en"
      targetLang="el"
      inputLabel="English"
      outputLabel="Greek"
      inputPlaceholder="Type or paste your English text here..."
      outputPlaceholder="Your Greek translation will appear here..."
    />
    <div class="info-block">
      <h3>About <span class="gold-text">Greek</span></h3>
      <p>Modern Greek is spoken by approximately 13 million people, primarily in Greece and Cyprus. It is a direct descendant of Ancient Greek — one of the world's oldest recorded languages — with an unbroken literary tradition spanning over 3,000 years. Greek has contributed thousands of words to English and other European languages.</p>
      <p>This translator is ideal for travel to Greece and Cyprus, academic research, business communication, and studying classical texts. For ancient varieties, visit the <a href="/ancient-greek/">Ancient Greek Translator</a>. Return to <a href="/language-translators/">Language Translators</a>.</p>
    </div>
  </ToolPageLayout>
</Layout>
