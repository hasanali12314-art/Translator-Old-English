---
import Layout from '../../layouts/Layout.astro';
import PageSeoSections from '../../components/PageSeoSections.astro';
import { PAGE_SEO_CONTENT } from '../../data/pageSeoContent';
import ToolPageLayout from '../../components/ToolPageLayout.astro';
import TranslatorTool from '../../components/TranslatorTool.astro';

const related = [
  { href: '/rare-languages/', name: 'Rare Languages' },
  { href: '/sinhala-translator/', name: 'Sinhala' },
  { href: '/dialect-translator/', name: 'Dialect Converter' },
];

const examples = [
  { inputLabel: 'English', outputLabel: 'Navajo (Diné)', input: 'Hello, my friend.', output: "Yá'át'ééh, shik'is." },
  { inputLabel: 'English', outputLabel: 'Navajo (Diné)', input: 'The land is sacred.', output: "Nizhóní nohookáá' diyin." },
  { inputLabel: 'English', outputLabel: 'Navajo (Diné)', input: 'Thank you.', output: "Ahéhee'." },
];

const titleHtml = 'Navajo <span class="gold-text">Converter</span>';

---
<Layout title="Navajo Translator — English to Diné Bizaad Free" description="Translate English to Navajo (Diné Bizaad) or Navajo to English. Free AI-powered Navajo language converter, culturally respectful." canonical="/navajo-translator/">
  <ToolPageLayout
    breadcrumb={[
      { href: '/', label: 'Home' },
      { href: '/specialty-translators/', label: 'Specialty Translators' },
      { label: 'Navajo Converter' },
    ]}
    backLink={{ href: '/specialty-translators/', label: '← Back to Specialty Translators' }}
    titleHtml={titleHtml}
    toolLabel="Navajo"
    heroSub="Translate English to Navajo (Diné Bizaad) — free, culturally respectful, AI-powered translation"
    examplesSub="Click any card to load it into the translator"
    examples={examples}
    related={related}
    relatedTitle="Related Tools"
    relatedBack={{ href: '/specialty-translators/', label: 'Back to Specialty Translators' }}
    ctaTitle='Translate to <span class="gold-text">Navajo</span> Now'
    ctaSub="Free, instant, culturally respectful Navajo translation"
    ctaBtn="✦ Start Translating"
  >
    <TranslatorTool
      slot="tool"
      sourceLang="en"
      targetLang="nv"
      inputLabel="English"
      outputLabel="Navajo (Diné Bizaad)"
      inputPlaceholder="Type or paste your English text here..."
      outputPlaceholder="Diné Bizaad translation will appear here..."
    />
    <div class="info-block">
      <h3>About <span class="gold-text">Navajo (Diné Bizaad)</span></h3>
      <p>Navajo (Diné Bizaad) is the most widely spoken Native American language in the United States, with approximately 170,000 speakers primarily in the Navajo Nation spanning Arizona, New Mexico, and Utah. It is a Na-Dené language known for its complex verb morphology and tonal qualities. The Navajo Code Talkers of World War II used the language's complexity as an unbreakable military code. Return to <a href="/specialty-translators/">Specialty Translators</a>.</p>
    </div>
    <PageSeoSections {...PAGE_SEO_CONTENT['navajo-translator']} />
  </ToolPageLayout>
</Layout>
