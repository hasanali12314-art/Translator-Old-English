---
import Layout from '../../layouts/Layout.astro';
import ToolPageLayout from '../../components/ToolPageLayout.astro';
import TranslatorTool from '../../components/TranslatorTool.astro';

const related = [
  { href: '/dialect-translator/', name: 'Dialect Converter' },
  { href: '/speak-translate/', name: 'Speak Translator' },
  { href: '/rare-languages/', name: 'Rare Languages' },
];

const examples = [
  { inputLabel: 'Normal Text', outputLabel: 'Fancy Output', input: 'Hello World', output: '𝓗𝓮𝓵𝓵𝓸 𝓦𝓸𝓻𝓵𝓭' },
  { inputLabel: 'Normal Text', outputLabel: 'Fancy Output', input: 'Hello World', output: 'ℍ𝕖𝕝𝕝𝕠 𝕎𝕠𝕣𝕝𝕕' },
  { inputLabel: 'Normal Text', outputLabel: 'Fancy Output', input: 'Hello World', output: 'Ĥēłłö Wörłd' },
];

const titleHtml = 'Fancy Text <span class="gold-text">Converter</span>';

---
<Layout title="Fancy Text Generator — Stylised & Decorative Text Converter Free" description="Convert normal text into fancy, stylised, and decorative Unicode text styles. Free online fancy text generator." canonical="/fancy-translator/">
  <ToolPageLayout
    breadcrumb={[
      { href: '/translator-old-english/', label: 'Home' },
      { href: '/specialty-translators/', label: 'Specialty Translators' },
      { label: 'Fancy Text Converter' },
    ]}
    backLink={{ href: '/specialty-translators/', label: '← Back to Specialty Translators' }}
    titleHtml={titleHtml}
    heroSub="Transform normal text into stylised, decorative, and fancy Unicode styles — perfect for social media"
    examplesTitle="Style Examples"
    examplesSub="Click any card to load it into the translator"
    examples={examples}
    related={related}
    relatedTitle="Related Tools"
    relatedBack={{ href: '/specialty-translators/', label: 'Back to Specialty Translators' }}
    ctaTitle='Create <span class="gold-text">Fancy Text</span> Now'
    ctaSub="Free, instant Unicode text styling"
    ctaBtn="✦ Convert Now"
  >
    <TranslatorTool
      slot="tool"
      mode="fancy"
      showFancyStyleDropdown={true}
      sourceLang="en"
      targetLang="en"
      inputLabel="Normal Text"
      outputLabel="Fancy / Stylised Output"
      inputPlaceholder="Type your normal text here..."
      outputPlaceholder="Your fancy text will appear here..."
    />
    <div class="info-block">
      <h2>About <span class="gold-text">Fancy Text</span></h2>
      <p>The Fancy Text Converter uses Unicode character sets to transform standard text into decorative styles. These work across social media platforms like Instagram, Twitter, TikTok, and Discord. Styles include cursive, bold serif, hollow, strikethrough, and many more. Return to <a href="/specialty-translators/">Specialty Translators</a>.</p>
    </div>
  </ToolPageLayout>
</Layout>
