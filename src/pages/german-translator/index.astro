---
import Layout from '../../layouts/Layout.astro';
import ToolPageLayout from '../../components/ToolPageLayout.astro';
import TranslatorTool from '../../components/TranslatorTool.astro';

const related = [
  { href: '/french-translator/', name: 'French Translator' },
  { href: '/spanish-translator/', name: 'Spanish Translator' },
  { href: '/creole-translator/', name: 'Creole Translator' },
];

const examples = [
  { inputLabel: 'English', outputLabel: 'German', input: 'Good morning, how can I help you?', output: 'Guten Morgen, wie kann ich Ihnen helfen?' },
  { inputLabel: 'English', outputLabel: 'German', input: "The train departs at nine o'clock.", output: 'Der Zug fährt um neun Uhr ab.' },
  { inputLabel: 'English', outputLabel: 'German', input: 'I love hiking in the mountains.', output: 'Ich liebe es, in den Bergen zu wandern.' },
];

const titleHtml = 'German <span class="gold-text">Translator</span>';

---
<Layout title="German Translator — English to German Free Online" description="Translate English to German or German to English instantly. Free AI-powered German translation with compound word support." canonical="/german-translator/">
  <ToolPageLayout
    breadcrumb={[
      { href: '/', label: 'Home' },
      { href: '/language-translators/', label: 'Language Translators' },
      { label: 'German Translator' },
    ]}
    backLink={{ href: '/language-translators/', label: '← Back to Language Translators' }}
    titleHtml={titleHtml}
    toolLabel="German"
    heroSub="Translate English to German or German to English — standard Hochdeutsch, free and instant"
    examplesSub="Click any card to load it into the translator"
    examples={examples}
    related={related}
    relatedBack={{ href: '/language-translators/', label: 'Browse all Language Translators' }}
    ctaTitle='Translate to <span class="gold-text">German</span> Now'
    ctaSub="Free, instant, AI-powered German translation"
    ctaBtn="✦ Start Translating"
  >
    <TranslatorTool
      slot="tool"
      sourceLang="en"
      targetLang="de"
      inputLabel="English"
      outputLabel="German"
      inputPlaceholder="Type or paste your English text here..."
      outputPlaceholder="Ihre deutsche Übersetzung erscheint hier..."
    />
    <div class="info-block">
      <h3>About <span class="gold-text">German</span></h3>
      <p>German is spoken by approximately 100 million native speakers and is the most widely spoken language in the European Union. It is the official language of Germany, Austria, Switzerland, Liechtenstein, Luxembourg, and Belgium. German is renowned for its compound words, precise grammar, and contribution to philosophy, science, and literature.</p>
      <p>This translator outputs standard Hochdeutsch and handles German compound words, noun capitalisation, and grammatical cases. Return to <a href="/language-translators/">Language Translators</a>.</p>
    </div>
  </ToolPageLayout>
</Layout>
