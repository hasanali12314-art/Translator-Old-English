---
import Layout from '../../layouts/Layout.astro';
import ToolPageLayout from '../../components/ToolPageLayout.astro';
import TranslatorTool from '../../components/TranslatorTool.astro';

const related = [
  { href: '/latin-translator/', name: 'Latin Translator' },
  { href: '/old-english/', name: 'Old English' },
  { href: '/greek-translator/', name: 'Modern Greek' },
];

const examples = [
  { inputLabel: 'Modern English', outputLabel: 'Ancient Greek', input: 'Know thyself.', output: 'Γνῶθι σεαυτόν.' },
  { inputLabel: 'Modern English', outputLabel: 'Ancient Greek', input: 'In the beginning was the Word.', output: 'Ἐν ἀρχῇ ἦν ὁ Λόγος.' },
  { inputLabel: 'Modern English', outputLabel: 'Ancient Greek', input: 'Nothing in excess.', output: 'Μηδὲν ἄγαν.' },
];

const titleHtml = 'Ancient Greek <span class="gold-text">Translator</span>';

---
<Layout title="Ancient Greek Translator — Koine & Classical" description="Translate English to Ancient Greek (Koine and Classical). Free AI-powered ancient Greek translation tool with style options." canonical="/ancient-greek/">
  <ToolPageLayout
    breadcrumb={[
      { href: '/', label: 'Home' },
      { href: '/ancient-languages/', label: 'Ancient Languages' },
      { label: 'Ancient Greek Translator' },
    ]}
    backLink={{ href: '/ancient-languages/', label: '← Back to Ancient Languages' }}
    titleHtml={titleHtml}
    toolLabel="Ancient Greek"
    heroSub="Translate English to Koine or Classical Ancient Greek — free, AI-powered, with style controls"
    examplesSub="Click any card to load it into the translator"
    examples={examples}
    related={related}
    relatedTitle="Related Pages"
    ctaTitle='Translate to <span class="gold-text">Ancient Greek</span> Now'
    ctaSub="Free, instant, AI-powered Ancient Greek translation"
    ctaBtn="✦ Start Translating"
  >
    <TranslatorTool
      slot="tool"
      sourceLang="en"
      targetLang="el"
      inputLabel="Modern English"
      outputLabel="Ancient Greek"
      inputPlaceholder="Type or paste your modern English text here..."
      outputPlaceholder="Ἡ ἀρχαία Ἑλληνικὴ μετάφρασίς σου ὧδε φανεῖται..."
      showStyleDropdown={true}
      showAdvanced={true}
    />
    <div class="info-block">
      <h3>About <span class="gold-text">Ancient Greek</span></h3>
      <p>Ancient Greek was spoken in the Greek world from approximately 800 BCE to 600 CE. Classical Greek (Attic dialect) is the language of Plato, Aristotle, Sophocles, and Thucydides. Koine Greek — the "common" language — spread across the Mediterranean with Alexander the Great's conquests and is the language of the New Testament. Together, these dialects form the foundation of Western philosophy, literature, mathematics, and science.</p>
      <p>For Modern Greek, visit the <a href="/greek-translator/">Greek Translator</a>. Return to <a href="/ancient-languages/">Ancient Languages</a>.</p>
    </div>
  </ToolPageLayout>
</Layout>
