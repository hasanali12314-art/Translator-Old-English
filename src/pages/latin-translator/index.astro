---
import Layout from '../../layouts/Layout.astro';
import ToolPageLayout from '../../components/ToolPageLayout.astro';
import TranslatorTool from '../../components/TranslatorTool.astro';

const related = [
  { href: '/old-english/', name: 'Anglo-Saxon Old English' },
  { href: '/aramaic-translator/', name: 'Aramaic Translator' },
];

const examples = [
  { inputLabel: 'Modern English', outputLabel: 'Latin', input: 'I came, I saw, I conquered.', output: 'Veni, vidi, vici.' },
  { inputLabel: 'Modern English', outputLabel: 'Latin', input: 'Knowledge is power.', output: 'Scientia est potentia.' },
  { inputLabel: 'Modern English', outputLabel: 'Latin', input: 'Time flies and cannot be recalled.', output: 'Tempus fugit nec potest revocari.' },
];

const titleHtml = 'Latin <span class="gold-text">Translator</span>';

---
<Layout title="Latin Translator — English to Latin Free Online" description="Translate English to Latin or Latin to English instantly. Classical and Ecclesiastical Latin with style options. Free AI-powered." canonical="/latin-translator/">
  <ToolPageLayout
    breadcrumb={[
      { href: '/translator-old-english/', label: 'Home' },
      { href: '/ancient-languages/', label: 'Ancient Languages' },
      { label: 'Latin Translator' },
    ]}
    backLink={{ href: '/ancient-languages/', label: '← Back to Ancient Languages' }}
    titleHtml={titleHtml}
    heroSub="Translate English to Classical or Ecclesiastical Latin — free, AI-powered, with advanced style controls"
    examplesTitle="Translation Examples"
    examplesSub="Click any card to load it into the translator"
    examples={examples}
    related={related}
    relatedTitle="Related Pages"
    ctaTitle='Translate to <span class="gold-text">Latin</span> Now'
    ctaSub="Free, instant, AI-powered Latin translation"
    ctaBtn="✦ Start Translating"
  >
    <TranslatorTool
      slot="tool"
      sourceLang="en"
      targetLang="la"
      inputLabel="Modern English"
      outputLabel="Latin"
      inputPlaceholder="Type or paste your modern English text here..."
      outputPlaceholder="Latina translatio tua hic apparebit..."
      showStyleDropdown={true}
      showAdvanced={true}
    />
    <div class="info-block">
      <h2>About <span class="gold-text">Latin</span></h2>
      <p>Latin was the language of the Roman Empire and served as the lingua franca of European scholarship, law, medicine, and the Catholic Church for over a millennium. It is the ancestor of the Romance languages — Italian, Spanish, French, Portuguese, and Romanian — and has contributed enormously to English vocabulary. Although no longer spoken natively, Latin remains essential in law, medicine, academia, Catholic liturgy, and classical studies.</p>
    </div>
  </ToolPageLayout>
</Layout>
