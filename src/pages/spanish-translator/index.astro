---
import Layout from '../../layouts/Layout.astro';
import TranslatorTool from '../../components/TranslatorTool.astro';
---
<Layout title="Spanish Translator — English to Spanish Free Online" description="Translate English to Spanish or Spanish to English instantly. Free AI-powered Spanish translation for Latin American and European Spanish." canonical="/spanish-translator/">
<section class="hero-section"><div class="container">
  <nav class="breadcrumb" style="margin-bottom:16px;"><a href="/translator-old-english/">Home</a><span>›</span><a href="/language-translators/">Language Translators</a><span>›</span><span>Spanish Translator</span></nav>
  <a href="/language-translators/" class="btn btn-ghost btn-sm" style="margin-bottom:24px;">← Back to Language Translators</a>
  <h1 id="main-heading">Spanish <span class="gold-text">Translator</span></h1>
  <p class="hero-sub">Translate English to Spanish or Spanish to English — Latin American &amp; European Spanish, free and instant</p>
</div></section>
<section class="section-sm"><div class="container"><TranslatorTool sourceLang="en" targetLang="es" inputLabel="English" outputLabel="Spanish" inputPlaceholder="Type or paste your English text here..." outputPlaceholder="Tu traducción al español aparecerá aquí..." /></div></section>
<section class="section-sm"><div class="container">
  <div class="section-heading"><h2>Translation <span class="gold-text">Examples</span></h2></div>
  <div class="grid-3">
    {[{e:'Where is the train station?',s:'¿Dónde está la estación de tren?'},{e:'I would like to order, please.',s:'Me gustaría pedir, por favor.'},{e:'The sunset was absolutely beautiful.',s:'El atardecer fue absolutamente hermoso.'}].map(ex=>(
      <div class="example-card"><div class="example-card-section"><div class="example-label">English</div><div class="example-text">{ex.e}</div></div><div class="example-card-section"><div class="example-label">Spanish</div><div class="example-text" style="color:var(--gold-light);">{ex.s}</div></div></div>
    ))}
  </div>
</div></section>
<section class="section"><div class="container" style="max-width:800px;">
  <h2 style="margin-bottom:16px;">About <span class="gold-text">Spanish</span></h2>
  <p style="color:var(--text-secondary);line-height:1.8;margin-bottom:20px;">Spanish is the second most spoken language in the world by native speakers, with over 500 million speakers across Spain, Latin America, the United States, and beyond. It is an official language in 21 countries and is the third most used language on the internet.</p>
  <p style="color:var(--text-secondary);line-height:1.8;">This tool is perfect for travel, business, language learning, and content creation. It handles both European and Latin American Spanish vocabulary. Return to <a href="/language-translators/">Language Translators</a>.</p>
</div></section>
<section class="section-sm"><div class="container">
  <div class="section-heading"><h2>Related <span class="gold-text">Translators</span></h2></div>
  <div class="grid-4">{[{href:'/chinese-translator/',n:'Chinese'},{href:'/arabic-translator/',n:'Arabic'},{href:'/french-translator/',n:'French'},{href:'/german-translator/',n:'German'}].map(r=>(<a href={r.href} class="card" style="text-decoration:none;text-align:center;font-weight:600;font-size:0.9rem;">{r.n}</a>))}</div>
  <div style="text-align:center;margin-top:24px;"><a href="/language-translators/" class="btn btn-outline">Browse all Language Translators</a></div>
</div></section>
<section class="section"><div class="container" style="max-width:800px;">
  <div class="section-heading"><h2>Frequently Asked <span class="gold-text">Questions</span></h2></div>
  {[{q:'Does it support Latin American and European Spanish?',a:'Yes. The translator handles vocabulary from both Latin American and European Spanish variants.'},{q:'Can I translate Spanish back to English?',a:'Yes. Use the flip button to reverse the translation direction.'},{q:'Is this tool free to use?',a:'Completely free, no account required.'},{q:'What is the character limit?',a:'Up to 5,000 characters per translation.'},{q:'How accurate is the Spanish translation?',a:'Very accurate. Spanish is one of the most well-supported languages in AI translation.'},{q:'Does it work on mobile?',a:'Yes, fully responsive on all devices.'},{q:'Can I use translations commercially?',a:'Yes, all output is free for commercial use.'},{q:'Is there a word limit per session?',a:'No session limit — translate as many times as you need.'}].map(f=>(<div class="faq-item"><button class="faq-question">{f.q}<span class="faq-icon">+</span></button><div class="faq-answer">{f.a}</div></div>))}
</div></section>
<section class="section-sm"><div class="container"><div class="cta-banner">
  <h2 style="margin-bottom:16px;">Translate to <span class="gold-text">Spanish</span> Now</h2>
  <a href="#tool-area" class="btn btn-primary btn-lg" style="margin-bottom:32px;">✦ Start Translating</a>
  <div class="trust-badges"><div class="trust-badge"><div class="trust-badge-icon">🆓</div> Free forever</div><div class="trust-badge"><div class="trust-badge-icon">⚡</div> Instant results</div><div class="trust-badge"><div class="trust-badge-icon">🤖</div> AI-powered accuracy</div></div>
</div></div></section>
</Layout>
