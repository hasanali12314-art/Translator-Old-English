---
import Layout from '../../layouts/Layout.astro';
import ToolPageLayout from '../../components/ToolPageLayout.astro';
import TranslatorTool from '../../components/TranslatorTool.astro';

const related = [
  { href: '/chinese-translator/', name: 'Chinese Translator' },
  { href: '/arabic-translator/', name: 'Arabic Translator' },
  { href: '/french-translator/', name: 'French Translator' },
  { href: '/german-translator/', name: 'German Translator' },
];

const examples = [
  { inputLabel: 'English', outputLabel: 'Spanish', input: 'Where is the train station?', output: '¿Dónde está la estación de tren?' },
  { inputLabel: 'English', outputLabel: 'Spanish', input: 'I would like to order, please.', output: 'Me gustaría pedir, por favor.' },
  { inputLabel: 'English', outputLabel: 'Spanish', input: 'The sunset was absolutely beautiful.', output: 'El atardecer fue absolutamente hermoso.' },
];

const titleHtml = 'Spanish <span class="gold-text">Translator</span>';

---
<Layout title="Spanish Translator — English to Spanish Free Online" description="Translate English to Spanish or Spanish to English instantly. Free AI-powered Spanish translation for Latin American and European Spanish." canonical="/spanish-translator/">
  <ToolPageLayout
    breadcrumb={[
      { href: '/', label: 'Home' },
      { href: '/language-translators/', label: 'Language Translators' },
      { label: 'Spanish Translator' },
    ]}
    backLink={{ href: '/language-translators/', label: '← Back to Language Translators' }}
    titleHtml={titleHtml}
    heroSub="Translate English to Spanish or Spanish to English — Latin American &amp; European Spanish, free and instant"
    examplesTitle="Translation Examples"
    examplesSub="Click any card to load it into the translator"
    examples={examples}
    related={related}
    relatedBack={{ href: '/language-translators/', label: 'Browse all Language Translators' }}
    ctaTitle='Translate to <span class="gold-text">Spanish</span> Now'
    ctaSub="Free, instant, AI-powered Spanish translation"
    ctaBtn="✦ Start Translating"
  >
    <TranslatorTool
      slot="tool"
      sourceLang="en"
      targetLang="es"
      inputLabel="English"
      outputLabel="Spanish"
      inputPlaceholder="Type or paste your English text here..."
      outputPlaceholder="Tu traducción al español aparecerá aquí..."
    />
    <div class="info-block">
      <h2>About <span class="gold-text">Spanish</span></h2>
      <p>Spanish is the second most spoken language in the world by native speakers, with over 500 million speakers across Spain, Latin America, the United States, and beyond. It is an official language in 21 countries and is the third most used language on the internet.</p>
      <p>This tool is perfect for travel, business, language learning, and content creation. It handles both European and Latin American Spanish vocabulary. Return to <a href="/language-translators/">Language Translators</a>.</p>
    </div>
  </ToolPageLayout>
</Layout>
