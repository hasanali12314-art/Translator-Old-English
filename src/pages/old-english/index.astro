---
import Layout from '../../layouts/Layout.astro';
import ToolPageLayout from '../../components/ToolPageLayout.astro';
import TranslatorTool from '../../components/TranslatorTool.astro';

const related = [
  { href: '/latin-translator/', name: 'Latin Translator' },
  { href: '/aramaic-translator/', name: 'Aramaic Translator' },
];

const examples = [
  { inputLabel: 'Modern English', outputLabel: 'Old English', input: 'Listen! We have heard of the glory of kings.', output: 'Hwæt! We Gardena in geardagum þeodcyninga þrym gefrunon.' },
  { inputLabel: 'Modern English', outputLabel: 'Old English', input: 'The warrior was brave and strong.', output: 'Se cempa wæs beald ond strang.' },
  { inputLabel: 'Modern English', outputLabel: 'Old English', input: 'The sea roared in the storm.', output: 'Sæ hlynede on þæm ðumre.' },
];

const titleHtml = 'Anglo-Saxon <span class="gold-text">Old English</span>';

---
<Layout title="Anglo-Saxon & Old Norse Translator — Free" description="Translate English to Old English (Anglo-Saxon) or Old Norse. Free AI-powered ancient English translation with style and advanced controls." canonical="/old-english/">
  <ToolPageLayout
    breadcrumb={[
      { href: '/', label: 'Home' },
      { href: '/ancient-languages/', label: 'Ancient Languages' },
      { label: 'Anglo-Saxon Old English' },
    ]}
    backLink={{ href: '/ancient-languages/', label: '← Back to Ancient Languages' }}
    titleHtml={titleHtml}
    heroSub="Translate to authentic Anglo-Saxon Old English or Old Norse — free, AI-powered, with style controls"
    examplesTitle="Translation Examples"
    examplesSub="Click any card to load it into the translator"
    examples={examples}
    related={related}
    relatedTitle="Related Pages"
    ctaTitle='Translate to <span class="gold-text">Old English</span> Now'
    ctaSub="Free, instant, AI-powered Old English translation"
    ctaBtn="✦ Start Translating"
  >
    <TranslatorTool
      slot="tool"
      mode="archaic"
      sourceLang="en"
      targetLang="ang"
      inputLabel="Modern English"
      outputLabel="Old English / Old Norse"
      inputPlaceholder="Type or paste your modern English text here..."
      outputPlaceholder="Þin eald Englisc oþþe Norrœnn here gesewen bið..."
      showStyleDropdown={true}
      showAdvanced={true}
    />
    <div class="info-block">
      <h2>About <span class="gold-text">Old English & Old Norse</span></h2>
      <p>Old English (Anglo-Saxon) was spoken in England from approximately 450 to 1150 AD. It is a West Germanic language far removed from modern English — closer to modern German or Dutch — and is the language of Beowulf, the Anglo-Saxon Chronicle, and the works of Ælfric. Old Norse, spoken by the Vikings, heavily influenced Old English and shares grammatical features with it.</p>
    </div>
  </ToolPageLayout>
</Layout>
