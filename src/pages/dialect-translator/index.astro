---
import Layout from '../../layouts/Layout.astro';
import ToolPageLayout from '../../components/ToolPageLayout.astro';
import TranslatorTool from '../../components/TranslatorTool.astro';

const related = [
  { href: '/speak-translate/', name: 'Speak Translator' },
  { href: '/fancy-translator/', name: 'Fancy Text' },
  { href: '/rare-languages/', name: 'Rare Languages' },
];

const examples = [
  { inputLabel: 'Standard Text', outputLabel: 'Dialect Output', input: 'How are you doing today?', output: "Ow's tha doin' today, then?" },
  { inputLabel: 'Standard Text', outputLabel: 'Dialect Output', input: 'I am going to the shop.', output: "Ah'm ganin' doon tae the shoap." },
  { inputLabel: 'Standard Text', outputLabel: 'Dialect Output', input: 'That is very good, thank you.', output: "Tha's right champion, ta very much." },
];

const titleHtml = 'Dialect <span class="gold-text">Converter</span>';

---
<Layout title="Dialect Converter — Convert Text to Regional Dialects Free" description="Convert standard English text to regional dialects. Free AI-powered dialect converter tool online." canonical="/dialect-translator/">
  <ToolPageLayout
    breadcrumb={[
      { href: '/translator-old-english/', label: 'Home' },
      { href: '/specialty-translators/', label: 'Specialty Translators' },
      { label: 'Dialect Converter' },
    ]}
    backLink={{ href: '/specialty-translators/', label: '← Back to Specialty Translators' }}
    titleHtml={titleHtml}
    heroSub="Convert standard English text into authentic regional dialects — free, instant, AI-powered"
    examplesTitle="Conversion Examples"
    examplesSub="Click any card to load it into the translator"
    examples={examples}
    related={related}
    relatedTitle="Related Tools"
    relatedBack={{ href: '/specialty-translators/', label: 'Back to Specialty Translators' }}
    ctaTitle='Start <span class="gold-text">Converting Dialects</span>'
    ctaSub="Free, instant, AI-powered dialect conversion"
    ctaBtn="✦ Convert Now"
  >
    <TranslatorTool
      slot="tool"
      mode="dialect"
      showDialectDropdown={true}
      sourceLang="en"
      targetLang="en"
      inputLabel="Standard Text"
      outputLabel="Dialect Output"
      inputPlaceholder="Type or paste standard English text here..."
      outputPlaceholder="Your dialect conversion will appear here..."
    />
    <div class="info-block">
      <h2>About <span class="gold-text">Dialect Conversion</span></h2>
      <p>The Dialect Converter transforms standard English into regional dialect styles including Northern English, Scottish, Cockney, and others. It is ideal for writers creating authentic dialogue, linguists studying dialect patterns, and creatives adding regional flavour to their content. Return to <a href="/specialty-translators/">Specialty Translators</a>.</p>
    </div>
  </ToolPageLayout>
</Layout>
