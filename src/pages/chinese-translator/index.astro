---
import Layout from '../../layouts/Layout.astro';
import ToolPageLayout from '../../components/ToolPageLayout.astro';
import TranslatorTool from '../../components/TranslatorTool.astro';

const related = [
  { href: '/greek-translator/', name: 'Greek Translator' },
  { href: '/spanish-translator/', name: 'Spanish Translator' },
  { href: '/arabic-translator/', name: 'Arabic Translator' },
  { href: '/french-translator/', name: 'French Translator' },
  { href: '/german-translator/', name: 'German Translator' },
  { href: '/creole-translator/', name: 'Creole Translator' },
];

const examples = [
  { inputLabel: 'English', outputLabel: 'Chinese (Simplified)', input: 'Hello, nice to meet you.', output: '你好，很高兴认识你。' },
  { inputLabel: 'English', outputLabel: 'Chinese (Simplified)', input: 'Where is the nearest station?', output: '最近的车站在哪里？' },
  { inputLabel: 'English', outputLabel: 'Chinese (Simplified)', input: 'Thank you very much.', output: '非常感谢。' },
];

const titleHtml = 'Chinese <span class="gold-text">Translator</span>';

---
<Layout title="Chinese Translator — English to Chinese Free Online" description="Translate English to Chinese (Simplified and Traditional) or Chinese to English instantly. Free, AI-powered, no account needed." canonical="/chinese-translator/">
  <ToolPageLayout
    breadcrumb={[
      { href: '/', label: 'Home' },
      { href: '/language-translators/', label: 'Language Translators' },
      { label: 'Chinese Translator' },
    ]}
    backLink={{ href: '/language-translators/', label: '← Back to Language Translators' }}
    titleHtml={titleHtml}
    heroSub="Translate English to Chinese (Simplified &amp; Traditional) or Chinese to English — free, instant, AI-powered"
    examplesTitle="Translation Examples"
    examplesSub="Click any card to load it into the translator"
    examples={examples}
    related={related}
    relatedBack={{ href: '/language-translators/', label: 'Browse all Language Translators' }}
    ctaTitle='Translate to <span class="gold-text">Chinese</span> Now'
    ctaSub="Free, instant, AI-powered Chinese translation"
    ctaBtn="✦ Start Translating"
  >
    <TranslatorTool
      slot="tool"
      sourceLang="en"
      targetLang="zh-CN"
      inputLabel="English"
      outputLabel="Chinese"
      inputPlaceholder="Type or paste your English text here..."
      outputPlaceholder="Your Chinese translation will appear here..."
    />
    <div class="info-block">
      <h2>About <span class="gold-text">Chinese</span></h2>
      <p>Chinese is the world's most spoken language by native speakers, with over 1 billion speakers across China, Taiwan, Singapore, and diaspora communities worldwide. It exists in two written forms — Simplified (used in mainland China) and Traditional (used in Taiwan and Hong Kong) — and encompasses numerous spoken dialects including Mandarin, Cantonese, and Hokkien.</p>
      <p>This translator is ideal for business communication with Chinese partners, learning Mandarin, translating product information, academic research, and travel preparation. Return to <a href="/language-translators/">Language Translators</a> to explore other languages.</p>
    </div>
  </ToolPageLayout>
</Layout>
