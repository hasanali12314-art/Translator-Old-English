---
import Layout from '../../layouts/Layout.astro';
import ToolPageLayout from '../../components/ToolPageLayout.astro';
import TranslatorTool from '../../components/TranslatorTool.astro';

const related = [
  { href: '/latin-translator/', name: 'Latin Translator' },
  { href: '/egyptian-arabic/', name: 'Egyptian Arabic' },
];

const examples = [
  { inputLabel: 'Modern English', outputLabel: 'Aramaic', input: 'In the beginning was the Word.', output: 'Breshit hwā Miltha.' },
  { inputLabel: 'Modern English', outputLabel: 'Aramaic', input: 'Peace be upon you.', output: 'Shlama alaykun.' },
  { inputLabel: 'Modern English', outputLabel: 'Aramaic', input: 'Blessed are the merciful.', output: "Tubyhon l'rahmane." },
];

const titleHtml = 'Aramaic <span class="gold-text">Translator</span>';

---
<Layout title="Aramaic Translator — English to Aramaic Free" description="Translate English to Biblical Aramaic or Coptic. Free AI-powered ancient Semitic language translation tool." canonical="/aramaic-translator/">
  <ToolPageLayout
    breadcrumb={[
      { href: '/', label: 'Home' },
      { href: '/ancient-languages/', label: 'Ancient Languages' },
      { label: 'Aramaic Translator' },
    ]}
    backLink={{ href: '/ancient-languages/', label: '← Back to Ancient Languages' }}
    titleHtml={titleHtml}
    toolLabel="Aramaic"
    heroSub="Translate English to Biblical Aramaic or Coptic — free, AI-powered ancient language translation"
    examplesSub="Click any card to load it into the translator"
    examples={examples}
    related={related}
    relatedTitle="Related Pages"
    ctaTitle='Translate to <span class="gold-text">Aramaic</span> Now'
    ctaSub="Free, instant, AI-powered Aramaic translation"
    ctaBtn="✦ Start Translating"
  >
    <TranslatorTool
      slot="tool"
      sourceLang="en"
      targetLang="he"
      inputLabel="Modern English"
      outputLabel="Aramaic / Coptic"
      inputPlaceholder="Type or paste your modern English text here..."
      outputPlaceholder="Your Aramaic or Coptic translation will appear here..."
      showStyleDropdown={true}
      showAdvanced={true}
    />
    <div class="info-block">
      <h3>About <span class="gold-text">Aramaic & Coptic</span></h3>
      <p>Aramaic is one of the oldest continuously spoken languages in the world, originating around 1000 BCE in the ancient Near East. It was the lingua franca of the Persian Empire and the everyday language of Jesus and his contemporaries. Biblical Aramaic appears in portions of Daniel and Ezra. Coptic is the latest phase of the ancient Egyptian language, written in a modified Greek alphabet and still used liturgically in the Coptic Orthodox Church.</p>
    </div>
  </ToolPageLayout>
</Layout>
