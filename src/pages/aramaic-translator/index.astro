---
import Layout from '../../layouts/Layout.astro';
import TranslatorTool from '../../components/TranslatorTool.astro';
---
<Layout title="Aramaic Translator — English to Aramaic & Coptic Free Online" description="Translate English to Biblical Aramaic or Coptic. Free AI-powered ancient Semitic language translation tool." canonical="/aramaic-translator/">
<section class="hero-section"><div class="container">
  <nav class="breadcrumb" style="margin-bottom:16px"><a href="/translator-old-english/">Home</a><span>›</span><a href="/ancient-languages/">Ancient Languages</a><span>›</span><span>Aramaic Translator</span></nav>
  <a href="/ancient-languages/" class="btn btn-ghost btn-sm" style="margin-bottom:24px">← Back to Ancient Languages</a>
  <h1 id="main-heading">Aramaic <span class="gold-text">Translator</span></h1>
  <p class="hero-sub">Translate English to Biblical Aramaic or Coptic — free, AI-powered ancient language translation</p>
</div></section>
<section class="section-sm"><div class="container"><TranslatorTool sourceLang="en" targetLang="he" inputLabel="Modern English" outputLabel="Aramaic / Coptic" inputPlaceholder="Type or paste your modern English text here..." outputPlaceholder="Your Aramaic or Coptic translation will appear here..." showStyleDropdown={true} showAdvanced={true} /></div></section>
<section class="section-sm"><div class="container">
  <div class="section-heading"><h2>Translation <span class="gold-text">Examples</span></h2></div>
  <div class="grid-3">
    {[{e:'In the beginning was the Word.',a:'Breshit hwā Miltha.'},{e:'Peace be upon you.',a:'Shlama alaykun.'},{e:'Blessed are the merciful.',a:'Tubyhon l\'rahmane.'}].map(ex=>(
      <div class="example-card"><div class="example-card-section"><div class="example-label">Modern English</div><div class="example-text">{ex.e}</div></div><div class="example-card-section"><div class="example-label">Aramaic</div><div class="example-text" style="color:var(--gold-light)">{ex.a}</div></div></div>
    ))}
  </div>
</div></section>
<section class="section"><div class="container" style="max-width:800px">
  <h2 style="margin-bottom:16px">About <span class="gold-text">Aramaic & Coptic</span></h2>
  <p style="color:var(--text-secondary);line-height:1.8">Aramaic is one of the oldest continuously spoken languages in the world, originating around 1000 BCE in the ancient Near East. It was the lingua franca of the Persian Empire and the everyday language of Jesus and his contemporaries. Biblical Aramaic appears in portions of Daniel and Ezra. Coptic is the latest phase of the ancient Egyptian language, written in a modified Greek alphabet and still used liturgically in the Coptic Orthodox Church.</p>
</div></section>
<section class="section-sm"><div class="container">
  <div class="section-heading"><h2>Related <span class="gold-text">Pages</span></h2></div>
  <div class="grid-2" style="max-width:500px;margin:0 auto">{[{href:'/latin-translator/',n:'Latin Translator'},{href:'/egyptian-arabic/',n:'Egyptian Arabic'}].map(r=>(<a href={r.href} class="card" style="text-decoration:none;text-align:center;font-weight:600">{r.n}</a>))}</div>
</div></section>
<section class="section"><div class="container" style="max-width:800px">
  <div class="section-heading"><h2>Frequently Asked <span class="gold-text">Questions</span></h2></div>
  {[{q:'Is it Biblical Aramaic?',a:'Yes. The tool focuses on Biblical/Classical Aramaic as found in ancient religious and historical texts.'},{q:'Is Coptic also supported on this page?',a:'Yes. You can switch between Aramaic and Coptic output via the style selector.'},{q:'Can I translate both ways?',a:'Yes. Use the flip button to translate Aramaic or Coptic back to modern English.'},{q:'Is this tool free to use?',a:'Completely free, no account required.'},{q:'What is the character limit?',a:'Up to 5,000 characters per translation.'},{q:'How accurate is the Aramaic translation?',a:'Good approximation for Biblical Aramaic. These are less-resourced languages so the AI provides historically-informed outputs.'},{q:'Can I use it for religious or academic work?',a:'Yes, though for critical religious or academic purposes, expert verification is recommended.'},{q:'Can I use translations commercially?',a:'Yes. All output is free for personal and commercial use.'}].map(f=>(<div class="faq-item"><button class="faq-question">{f.q}<span class="faq-icon">+</span></button><div class="faq-answer">{f.a}</div></div>))}
</div></section>
<section class="section-sm"><div class="container"><div class="cta-banner">
  <h2 style="margin-bottom:16px">Translate to <span class="gold-text">Aramaic</span> Now</h2>
  <a href="#tool-area" class="btn btn-primary btn-lg" style="margin-bottom:32px">✦ Start Translating</a>
  <div class="trust-badges"><div class="trust-badge"><div class="trust-badge-icon">🆓</div> Free forever</div><div class="trust-badge"><div class="trust-badge-icon">⚡</div> Instant results</div><div class="trust-badge"><div class="trust-badge-icon">🤖</div> AI-powered accuracy</div></div>
</div></div></section>
</Layout>
