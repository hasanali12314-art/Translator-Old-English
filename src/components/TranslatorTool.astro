---
import type { TranslateMode } from '../lib/translate';
import { resolveLangCode } from '../lib/languages';
import ToolModeTabs from './ToolModeTabs.astro';

export interface Props {
  inputLabel?: string;
  outputLabel?: string;
  inputPlaceholder?: string;
  outputPlaceholder?: string;
  showStyleDropdown?: boolean;
  showFancyStyleDropdown?: boolean;
  showAdvanced?: boolean;
  showDialectDropdown?: boolean;
  sourceLanguages?: string[];
  targetLanguages?: string[];
  sourceLang?: string;
  targetLang?: string;
  mode?: TranslateMode;
}
const {
  inputLabel = 'Modern English',
  outputLabel = 'Translation',
  inputPlaceholder = 'Type or paste your text here...',
  outputPlaceholder = 'Your translation will appear here...',
  showStyleDropdown = false,
  showFancyStyleDropdown = false,
  showAdvanced = false,
  showDialectDropdown = false,
  sourceLanguages = [],
  targetLanguages = [],
  sourceLang = 'en',
  targetLang = 'es',
  mode = 'translate',
} = Astro.props;
const hasLangSelect = sourceLanguages.length > 0 || targetLanguages.length > 0;
---

<ToolModeTabs>
<div
  class="tool-area tool-card"
  id="tool-area"
  data-source-lang={sourceLang}
  data-target-lang={targetLang}
  data-mode={mode}
>
  {showStyleDropdown && (
    <div class="style-row tool-controls">
      <div class="field-wrap">
        <label class="field-label" for="style-select-c">Translation Style</label>
        <select class="select" id="style-select-c">
          <option value="early" title="Shakespeare Style вҖ” Early Modern English (1500sвҖ“1600s)">рҹҺӯ Early Modern (1500sвҖ“1600s)</option>
          <option value="middle" title="Medieval Style вҖ” Middle English (1300sвҖ“1400s)">рҹ“ң Middle English (1300sвҖ“1400s)</option>
          <option value="ancient" title="Anglo-Saxon вҖ” True Old English (800sвҖ“1000s)">вҡ”пёҸ Anglo-Saxon (800sвҖ“1000s)</option>
          <option value="simple" title="Archaic Simplified вҖ” Easy thee/thou style">вңЁ Archaic Simplified</option>
        </select>
      </div>
    </div>
  )}

  {showFancyStyleDropdown && (
    <div class="style-row tool-controls">
      <div class="field-wrap">
        <label class="field-label" for="fancy-style-select-c">Fancy Style</label>
        <select class="select" id="fancy-style-select-c">
          <option value="script">рқ“’рқ“ҫрқ“»рқ“јрқ“Ірқ“ҝрқ“® Script</option>
          <option value="bold">рқҗҒрқҗЁрқҗҘрқҗқ Serif</option>
          <option value="italic">рқҗјрқ‘Ўрқ‘Һрқ‘ҷрқ‘–рқ‘җ</option>
          <option value="fraktur">рқ”үрқ”Ҝрқ”һрқ”Ёрқ”ұрқ”Ірқ”Ҝ (Gothic)</option>
          <option value="double">рқ”»рқ• рқ•Ұрқ•“рқ•қрқ•–-рқ•Ҡрқ•Ҙрқ•Јрқ•Ұрқ•”рқ•ң</option>
          <option value="sans">рқ—Ұрқ—®рқ—»рқҳҖ-рқ—Ұрқ—Ірқ—ҝрқ—¶рқ—і</option>
          <option value="mono">рқҷјрқҡҳрқҡ—рқҡҳрқҡңрқҡҷрқҡҠрқҡҢрқҡҺ</option>
        </select>
      </div>
    </div>
  )}

  {showDialectDropdown && (
    <div class="style-row tool-controls">
      <div class="field-wrap">
        <label class="field-label" for="dialect-select-c">Dialect</label>
        <select class="select" id="dialect-select-c">
          <option value="british">рҹҮ¬рҹҮ§ British English</option>
          <option value="southern">рҹҮәрҹҮё Southern US</option>
          <option value="scottish">рҹҸҙу Ғ§у Ғўу Ғіу ҒЈу Ғҙу Ғҝ Scottish</option>
          <option value="australian">рҹҮҰрҹҮә Australian</option>
          <option value="irish">рҹҮ®рҹҮӘ Irish</option>
        </select>
      </div>
    </div>
  )}

  {hasLangSelect && (
    <div class="style-row" style="margin-bottom:18px">
      <div class="field-wrap">
        <label class="field-label" for="source-lang">From</label>
        <select class="select" id="source-lang">
          {sourceLanguages.map(l => <option value={resolveLangCode(l)} data-label={l}>{l}</option>)}
        </select>
      </div>
      <div class="field-wrap">
        <label class="field-label" for="target-lang">To</label>
        <select class="select" id="target-lang">
          {targetLanguages.map(l => <option value={resolveLangCode(l)} data-label={l}>{l}</option>)}
        </select>
      </div>
    </div>
  )}

  {showAdvanced && (
    <div class="advanced-panel">
      <button type="button" class="advanced-toggle adv-btn" id="advancedToggle2" aria-expanded="false">
        вҡҷ Advanced <span class="adv-chevron" id="advancedArrow2">вҖә</span>
      </button>
      <div class="advanced-content adv-panel" id="advancedContent2">
        <div class="adv-grid" style="display:grid;grid-template-columns:1fr 1fr;gap:18px">
          <div class="adv-item">
            <label>Formality Level</label>
            <input type="range" class="range-slider" min="1" max="5" value="3" style="width:100%;margin-top:8px">
            <div class="range-labels" style="display:flex;justify-content:space-between;font-size:9px;color:var(--muted-lt);margin-top:3px">
              <span>Casual</span><span>Ceremonial</span>
            </div>
          </div>
          <div class="adv-item">
            <div class="adv-row advanced-row">
              <label>Old Pronouns (thee/thou)</label>
              <button type="button" class="toggle active" data-toggle="pronouns" role="switch" aria-checked="true"></button>
            </div>
          </div>
          <div class="adv-item">
            <div class="adv-row advanced-row">
              <label>Old Verb Endings (-eth, -hath)</label>
              <button type="button" class="toggle active" data-toggle="verbs" role="switch" aria-checked="true"></button>
            </div>
          </div>
          <div class="adv-item">
            <div class="adv-row advanced-row">
              <label>Archaic Vocabulary</label>
              <button type="button" class="toggle active" data-toggle="vocab" role="switch" aria-checked="true"></button>
            </div>
          </div>
        </div>
      </div>
    </div>
  )}

  <div class="boxes tool-boxes">
    <div class="trans-row" style="display:contents">
      <div class="trans-side tool-box">
        <div class="trans-top">
          <span class="trans-lang">{inputLabel}</span>
          <span class="char-ct char-count"><span class="comp-char">0</span> / 5000</span>
        </div>
        <div class="textarea-wrap">
          <textarea class="tool-textarea comp-input" id="comp-input" placeholder={inputPlaceholder} maxlength="5000" aria-label="Input text"></textarea>
          <button type="button" class="mic-btn" data-speech-btn data-speech-for="comp-input" aria-label="Start voice input" title="Speak to type">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 1a3 3 0 00-3 3v8a3 3 0 006 0V4a3 3 0 00-3-3z"/><path d="M19 10v2a7 7 0 01-14 0v-2M12 19v4M8 23h8"/></svg>
          </button>
        </div>
      </div>
      <div class="trans-mid">
        <button type="button" class="swap-btn flip-btn comp-flip" title="Flip direction" aria-label="Flip translation direction">вҮ„</button>
        <span class="flip-lbl">Flip</span>
      </div>
      <div class="trans-side trans-out tool-box" style="position:relative">
        <div class="trans-top">
          <span class="trans-lang">{outputLabel}</span>
          <div class="trans-actions">
            <button type="button" class="copy-btn comp-copy" style="opacity:0">вҺҳ Copy</button>
            <button type="button" class="download-btn comp-download" style="opacity:0">вҶ“ Download</button>
          </div>
        </div>
        <div class="textarea-wrap">
          <textarea class="tool-textarea comp-output" placeholder={outputPlaceholder} readonly aria-live="polite"></textarea>
        </div>
      </div>
    </div>
  </div>

  <p class="comp-error" role="alert" style="display:none"></p>

  <div class="actions tool-actions">
    <button type="button" class="btn-clear btn btn-ghost comp-clear">вң• Clear</button>
    <button type="button" class="btn-translate btn btn-primary comp-translate">вңҰ Translate</button>
  </div>
</div>
</ToolModeTabs>
