    </nav>

    <!-- Header actions -->
    <div class="header-actions">
      <button class="icon-btn" id="historyBtn" title="Translation History" aria-label="Open translation history">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      </button>
      <button class="icon-btn" id="themeToggle" title="Toggle theme" aria-label="Toggle light/dark mode">
        <span class="theme-icon">🌙</span>
      </button>
      <button class="icon-btn mobile-menu-btn" id="mobileMenuBtn" aria-label="Open mobile menu">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 12h18M3 6h18M3 18h18"/></svg>
      </button>
    </div>
  </div>

  <!-- Mobile nav -->
  <div class="mobile-nav" id="mobileNav">
    <nav>
      <a href="/translator-old-english/" class="mobile-nav-link">Home</a>
      <a href="/all-languages/" class="mobile-nav-link">All Languages</a>
      <a href="/text-translator/" class="mobile-nav-link">Text Translator</a>
      <div class="mobile-nav-group">
        <span class="mobile-nav-label">Language Translators</span>
        <a href="/chinese-translator/" class="mobile-nav-sub">Chinese</a>
        <a href="/spanish-translator/" class="mobile-nav-sub">Spanish</a>
        <a href="/arabic-translator/" class="mobile-nav-sub">Arabic</a>
        <a href="/greek-translator/" class="mobile-nav-sub">Greek</a>
        <a href="/french-translator/" class="mobile-nav-sub">French</a>
        <a href="/german-translator/" class="mobile-nav-sub">German</a>
        <a href="/creole-translator/" class="mobile-nav-sub">Creole</a>
        <a href="/language-translators/" class="mobile-nav-sub" style="color:var(--gold);">See All →</a>
      </div>
      <div class="mobile-nav-group">
        <span class="mobile-nav-label">Ancient Languages</span>
        <a href="/latin-translator/" class="mobile-nav-sub">Latin</a>
        <a href="/old-english/" class="mobile-nav-sub">Old English</a>
        <a href="/ancient-greek/" class="mobile-nav-sub">Ancient Greek</a>
        <a href="/aramaic-translator/" class="mobile-nav-sub">Aramaic</a>
        <a href="/ancient-languages/" class="mobile-nav-sub" style="color:var(--gold);">See All →</a>
      </div>
      <div class="mobile-nav-group">
        <span class="mobile-nav-label">Specialty</span>
        <a href="/dialect-translator/" class="mobile-nav-sub">Dialect Converter</a>
        <a href="/fancy-translator/" class="mobile-nav-sub">Fancy Text</a>
        <a href="/rare-languages/" class="mobile-nav-sub">Rare Languages</a>
        <a href="/specialty-translators/" class="mobile-nav-sub" style="color:var(--gold);">See All →</a>
      </div>
      <a href="/tools-resources/" class="mobile-nav-link">Tools & Resources</a>
      <a href="/blog/" class="mobile-nav-link">Blog</a>
    </nav>
  </div>
</header>

<!-- Page content -->
<main>
  <slot />
</main>

<!-- FOOTER -->
