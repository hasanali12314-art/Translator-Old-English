---
import '../styles/global.css';
export interface Props {
  title: string;
  description?: string;
  canonical?: string;
}
const { title, description = 'Translator Old English — translate modern English to Old English using AI. Early, Middle, Ancient, or Simple styles. Free, instant, and historically accurate.', canonical } = Astro.props;
const base = Astro.url.origin;

function normPath(p: string) {
  if (!p || p === '/') return '/';
  return p.endsWith('/') ? p : `${p}/`;
}
const currentPath = normPath(Astro.url.pathname);
const isActive = (href: string) => currentPath === normPath(href);
const isHome = currentPath === '/';
const activeClass = (href: string) => (isActive(href) ? 'active' : '');
const homeActiveClass = () => (isHome ? 'active' : '');
---
<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/png" href="/favicon.png" />
  <link rel="apple-touch-icon" href="/favicon.png" />
  <meta name="description" content={description} />
  <title>{title}</title>
  {canonical && <link rel="canonical" href={`${base}${canonical}`} />}
  <link
    rel="preload"
    href="/fonts/cinzel-600.ttf"
    as="font"
    type="font/ttf"
    crossorigin
  />
  <link
    rel="preload"
    href="/fonts/im-fell-english-italic.ttf"
    as="font"
    type="font/ttf"
    crossorigin
  />
  <slot name="head" />
</head>
<body>

<div class="history-overlay" id="historyOverlay"></div>

<aside class="history-panel" id="historyPanel" role="complementary" aria-label="Translation history">
  <div class="history-header">
    <div>
      <h3 style="margin-bottom:4px;">Translation History</h3>
      <p class="text-xs" style="color:var(--text-muted);">Last 50 translations · stored locally</p>
    </div>
    <button class="btn btn-ghost btn-sm" id="closeHistory" aria-label="Close history">✕</button>
  </div>
  <div class="history-list" id="historyList">
    <div class="history-empty">
      <div style="margin-bottom:12px;">📜</div>
      <p>No translations yet.<br/>Your history will appear here.</p>
    </div>
  </div>
  <div style="padding:16px;border-top:1px solid var(--border);">
    <button class="btn btn-ghost btn-sm" id="clearAllHistory" style="width:100%;">Clear All History</button>
  </div>
</aside>

<header class="site-header" role="banner">
  <div class="header-inner container">
    <a href="/" class="site-logo" id="site-logo">
      <img src="/logo-icon.png" alt="Translator Old English logo" class="logo-img" width="36" height="36" />
      <span class="logo-main logo-mobile logo-desktop">Translator <em>Old English</em></span>
      <span class="logo-sub">Free AI-powered archaic language tool</span>
    </a>

    <nav class="desktop-nav" role="navigation" aria-label="Main navigation">
      <ul class="nav-list">
        <li><a href="/" class:list={['nav-link', homeActiveClass()]} aria-current={isHome ? 'page' : undefined}>Home</a></li>
        <li><a href="/all-languages/" class:list={['nav-link', activeClass('/all-languages/')]} aria-current={isActive('/all-languages/') ? 'page' : undefined}>All Languages</a></li>
        <li class="nav-dropdown">
          <button type="button" class="nav-link nav-dropdown-btn" aria-haspopup="true" aria-expanded="false">
            Language Translators <span class="nav-arrow">▾</span>
          </button>
          <div class="dropdown-menu" role="menu">
            <a href="/chinese-translator/" class:list={['dropdown-item', activeClass('/chinese-translator/')]} role="menuitem" aria-current={isActive('/chinese-translator/') ? 'page' : undefined}>🀄 Chinese Translator</a>
            <a href="/spanish-translator/" class:list={['dropdown-item', activeClass('/spanish-translator/')]} role="menuitem" aria-current={isActive('/spanish-translator/') ? 'page' : undefined}>🇪🇸 Spanish Translator</a>
            <a href="/arabic-translator/" class:list={['dropdown-item', activeClass('/arabic-translator/')]} role="menuitem" aria-current={isActive('/arabic-translator/') ? 'page' : undefined}>🌙 Arabic Translator</a>
            <div class="dropdown-divider"></div>
            <a href="/language-translators/" class:list={['dropdown-item', 'dropdown-see-all', activeClass('/language-translators/')]} role="menuitem" aria-current={isActive('/language-translators/') ? 'page' : undefined}>See All Languages →</a>
          </div>
        </li>
        <li class="nav-dropdown">
          <button type="button" class="nav-link nav-dropdown-btn" aria-haspopup="true" aria-expanded="false">
            Ancient Languages <span class="nav-arrow">▾</span>
          </button>
          <div class="dropdown-menu" role="menu">
            <a href="/latin-translator/" class:list={['dropdown-item', activeClass('/latin-translator/')]} role="menuitem" aria-current={isActive('/latin-translator/') ? 'page' : undefined}>🏛 Latin Translator</a>
            <a href="/old-english/" class:list={['dropdown-item', activeClass('/old-english/')]} role="menuitem" aria-current={isActive('/old-english/') ? 'page' : undefined}>⚔ Old English</a>
            <a href="/ancient-greek/" class:list={['dropdown-item', activeClass('/ancient-greek/')]} role="menuitem" aria-current={isActive('/ancient-greek/') ? 'page' : undefined}>🏺 Ancient Greek</a>
            <div class="dropdown-divider"></div>
            <a href="/ancient-languages/" class:list={['dropdown-item', 'dropdown-see-all', activeClass('/ancient-languages/')]} role="menuitem" aria-current={isActive('/ancient-languages/') ? 'page' : undefined}>See All Ancient →</a>
          </div>
        </li>
        <li class="nav-dropdown">
          <button type="button" class="nav-link nav-dropdown-btn" aria-haspopup="true" aria-expanded="false">
            Tools <span class="nav-arrow">▾</span>
          </button>
          <div class="dropdown-menu" role="menu">
            <a href="/dialect-translator/" class:list={['dropdown-item', activeClass('/dialect-translator/')]} role="menuitem" aria-current={isActive('/dialect-translator/') ? 'page' : undefined}>🗣 Dialect Converter</a>
            <a href="/fancy-translator/" class:list={['dropdown-item', activeClass('/fancy-translator/')]} role="menuitem" aria-current={isActive('/fancy-translator/') ? 'page' : undefined}>✨ Fancy Text</a>
            <a href="/speak-translate/" class:list={['dropdown-item', activeClass('/speak-translate/')]} role="menuitem" aria-current={isActive('/speak-translate/') ? 'page' : undefined}>🎙 Speak Translator</a>
            <a href="/sinhala-translator/" class:list={['dropdown-item', activeClass('/sinhala-translator/')]} role="menuitem" aria-current={isActive('/sinhala-translator/') ? 'page' : undefined}>🇱🇰 Sinhala Translator</a>
            <a href="/rare-languages/" class:list={['dropdown-item', activeClass('/rare-languages/')]} role="menuitem" aria-current={isActive('/rare-languages/') ? 'page' : undefined}>💎 Rare Languages</a>
            <a href="/navajo-translator/" class:list={['dropdown-item', activeClass('/navajo-translator/')]} role="menuitem" aria-current={isActive('/navajo-translator/') ? 'page' : undefined}>🪶 Navajo Translator</a>
            <div class="dropdown-divider"></div>
            <a href="/tools-resources/" class:list={['dropdown-item', 'dropdown-see-all', activeClass('/tools-resources/')]} role="menuitem" aria-current={isActive('/tools-resources/') ? 'page' : undefined}>See All Tools →</a>
          </div>
        </li>
        <li><a href="/blog/" class:list={['nav-link', activeClass('/blog/')]} aria-current={isActive('/blog/') ? 'page' : undefined}>Blog</a></li>
      </ul>
    </nav>

    <div class="header-actions">
      <button class="hdr-btn" id="historyBtn" title="Translation History" aria-label="Open translation history">
        <span class="hdr-icon">📜</span>
        <span class="hdr-label">History</span>
      </button>
      <button class="icon-btn" id="themeToggle" title="Toggle theme" aria-label="Toggle light/dark mode">
        <span class="theme-icon">🌙</span>
      </button>
      <button class="icon-btn mobile-menu-btn" id="mobileMenuBtn" aria-label="Open mobile menu" aria-expanded="false">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 12h18M3 6h18M3 18h18"/></svg>
      </button>
    </div>
  </div>

  <div class="mobile-nav" id="mobileNav">
    <nav>
      <a href="/" class:list={['mobile-nav-link', homeActiveClass()]}>Home</a>
      <a href="/all-languages/" class:list={['mobile-nav-link', activeClass('/all-languages/')]}>All Languages</a>
      <div class="mobile-nav-group">
        <span class="mobile-nav-label">Language Translators</span>
        <a href="/chinese-translator/" class:list={['mobile-nav-sub', activeClass('/chinese-translator/')]}>Chinese</a>
        <a href="/spanish-translator/" class:list={['mobile-nav-sub', activeClass('/spanish-translator/')]}>Spanish</a>
        <a href="/arabic-translator/" class:list={['mobile-nav-sub', activeClass('/arabic-translator/')]}>Arabic</a>
        <a href="/language-translators/" class:list={['mobile-nav-sub', 'mobile-nav-see-all', activeClass('/language-translators/')]}>See All Languages →</a>
      </div>
      <div class="mobile-nav-group">
        <span class="mobile-nav-label">Ancient Languages</span>
        <a href="/latin-translator/" class:list={['mobile-nav-sub', activeClass('/latin-translator/')]}>Latin</a>
        <a href="/old-english/" class:list={['mobile-nav-sub', activeClass('/old-english/')]}>Old English</a>
        <a href="/ancient-greek/" class:list={['mobile-nav-sub', activeClass('/ancient-greek/')]}>Ancient Greek</a>
        <a href="/ancient-languages/" class:list={['mobile-nav-sub', 'mobile-nav-see-all', activeClass('/ancient-languages/')]}>See All Ancient →</a>
      </div>
      <div class="mobile-nav-group">
        <span class="mobile-nav-label">Tools</span>
        <a href="/dialect-translator/" class:list={['mobile-nav-sub', activeClass('/dialect-translator/')]}>Dialect Converter</a>
        <a href="/fancy-translator/" class:list={['mobile-nav-sub', activeClass('/fancy-translator/')]}>Fancy Text</a>
        <a href="/speak-translate/" class:list={['mobile-nav-sub', activeClass('/speak-translate/')]}>Speak Translator</a>
        <a href="/sinhala-translator/" class:list={['mobile-nav-sub', activeClass('/sinhala-translator/')]}>Sinhala</a>
        <a href="/rare-languages/" class:list={['mobile-nav-sub', activeClass('/rare-languages/')]}>Rare Languages</a>
        <a href="/navajo-translator/" class:list={['mobile-nav-sub', activeClass('/navajo-translator/')]}>Navajo</a>
        <a href="/tools-resources/" class:list={['mobile-nav-sub', 'mobile-nav-see-all', activeClass('/tools-resources/')]}>See All Tools →</a>
      </div>
      <a href="/blog/" class:list={['mobile-nav-link', activeClass('/blog/')]}>Blog</a>
    </nav>
  </div>
</header>

<main>
  <slot />
</main>

<footer class="site-footer">
  <div class="footer-inner container">
    <div class="footer-grid">
      <div class="footer-brand">
        <a href="/" class="site-logo" style="margin-bottom:16px;display:inline-flex;">
          <span class="logo-main">Translator <em>Old English</em></span>
        </a>
        <p class="text-sm" style="color:var(--text-muted);line-height:1.7;max-width:260px;">
          Free AI-powered translation between modern English and historical styles — Early, Middle, Ancient, and more.
        </p>
      </div>
      <div class="footer-col">
        <h4>Languages</h4>
        <ul>
          <li><a href="/chinese-translator/" class:list={[activeClass('/chinese-translator/')]} aria-current={isActive('/chinese-translator/') ? 'page' : undefined}>Chinese Translator</a></li>
          <li><a href="/spanish-translator/" class:list={[activeClass('/spanish-translator/')]} aria-current={isActive('/spanish-translator/') ? 'page' : undefined}>Spanish Translator</a></li>
          <li><a href="/arabic-translator/" class:list={[activeClass('/arabic-translator/')]} aria-current={isActive('/arabic-translator/') ? 'page' : undefined}>Arabic Translator</a></li>
          <li><a href="/language-translators/" class:list={[activeClass('/language-translators/')]} aria-current={isActive('/language-translators/') ? 'page' : undefined}>See All Languages →</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h4>Ancient</h4>
        <ul>
          <li><a href="/latin-translator/" class:list={[activeClass('/latin-translator/')]} aria-current={isActive('/latin-translator/') ? 'page' : undefined}>Latin Translator</a></li>
          <li><a href="/old-english/" class:list={[activeClass('/old-english/')]} aria-current={isActive('/old-english/') ? 'page' : undefined}>Old English</a></li>
          <li><a href="/ancient-greek/" class:list={[activeClass('/ancient-greek/')]} aria-current={isActive('/ancient-greek/') ? 'page' : undefined}>Ancient Greek</a></li>
          <li><a href="/ancient-languages/" class:list={[activeClass('/ancient-languages/')]} aria-current={isActive('/ancient-languages/') ? 'page' : undefined}>See All Ancient →</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h4>Tools</h4>
        <ul>
          <li><a href="/dialect-translator/" class:list={[activeClass('/dialect-translator/')]} aria-current={isActive('/dialect-translator/') ? 'page' : undefined}>Dialect Converter</a></li>
          <li><a href="/fancy-translator/" class:list={[activeClass('/fancy-translator/')]} aria-current={isActive('/fancy-translator/') ? 'page' : undefined}>Fancy Text</a></li>
          <li><a href="/speak-translate/" class:list={[activeClass('/speak-translate/')]} aria-current={isActive('/speak-translate/') ? 'page' : undefined}>Speak Translator</a></li>
          <li><a href="/sinhala-translator/" class:list={[activeClass('/sinhala-translator/')]} aria-current={isActive('/sinhala-translator/') ? 'page' : undefined}>Sinhala Translator</a></li>
          <li><a href="/rare-languages/" class:list={[activeClass('/rare-languages/')]} aria-current={isActive('/rare-languages/') ? 'page' : undefined}>Rare Languages</a></li>
          <li><a href="/navajo-translator/" class:list={[activeClass('/navajo-translator/')]} aria-current={isActive('/navajo-translator/') ? 'page' : undefined}>Navajo Translator</a></li>
          <li><a href="/tools-resources/" class:list={[activeClass('/tools-resources/')]} aria-current={isActive('/tools-resources/') ? 'page' : undefined}>See All Tools →</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h4>Legal</h4>
        <ul>
          <li><a href="/about-us/" class:list={[activeClass('/about-us/')]} aria-current={isActive('/about-us/') ? 'page' : undefined}>About Us</a></li>
          <li><a href="/blog/" class:list={[activeClass('/blog/')]} aria-current={isActive('/blog/') ? 'page' : undefined}>Blog</a></li>
          <li><a href="/privacy-policy/" class:list={[activeClass('/privacy-policy/')]} aria-current={isActive('/privacy-policy/') ? 'page' : undefined}>Privacy Policy</a></li>
          <li><a href="/terms-and-conditions/" class:list={[activeClass('/terms-and-conditions/')]} aria-current={isActive('/terms-and-conditions/') ? 'page' : undefined}>Terms & Conditions</a></li>
          <li><a href="/cookies/" class:list={[activeClass('/cookies/')]} aria-current={isActive('/cookies/') ? 'page' : undefined}>Cookies Policy</a></li>
          <li><a href="/sitemap/" class:list={[activeClass('/sitemap/')]} aria-current={isActive('/sitemap/') ? 'page' : undefined}>Sitemap</a></li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <p class="text-sm" style="color:var(--text-muted);">© 2026 Translator Old English. Free for personal and commercial use.</p>
      <div class="text-sm" style="display:flex;gap:16px;">
        <a href="/privacy-policy/" class:list={['footer-meta-link', activeClass('/privacy-policy/')]} style="color:var(--text-muted);">Privacy</a>
        <a href="/terms-and-conditions/" class:list={['footer-meta-link', activeClass('/terms-and-conditions/')]} style="color:var(--text-muted);">Terms</a>
        <a href="/sitemap/" class:list={['footer-meta-link', activeClass('/sitemap/')]} style="color:var(--text-muted);">Sitemap</a>
      </div>
    </div>
  </div>
</footer>

<script>
  const themeToggle = document.getElementById('themeToggle');
  const themeIcon = themeToggle?.querySelector('.theme-icon');
  const html = document.documentElement;
  let theme = localStorage.getItem('oe-theme') || 'dark';
  html.setAttribute('data-theme', theme);
  if (themeIcon) themeIcon.textContent = theme === 'dark' ? '🌙' : '☀️';
  themeToggle?.addEventListener('click', () => {
    theme = theme === 'dark' ? 'light' : 'dark';
    html.setAttribute('data-theme', theme);
    localStorage.setItem('oe-theme', theme);
    if (themeIcon) themeIcon.textContent = theme === 'dark' ? '🌙' : '☀️';
  });

  document.querySelectorAll('.nav-dropdown').forEach((dropdown) => {
    const btn = dropdown.querySelector('.nav-dropdown-btn');
    dropdown.addEventListener('click', (e) => e.stopPropagation());
    btn?.addEventListener('click', (e) => {
      e.stopPropagation();
      const open = dropdown.classList.toggle('open');
      btn.setAttribute('aria-expanded', String(open));
      document.querySelectorAll('.nav-dropdown').forEach((d) => {
        if (d !== dropdown) {
          d.classList.remove('open');
          d.querySelector('.nav-dropdown-btn')?.setAttribute('aria-expanded', 'false');
        }
      });
    });
  });
  document.addEventListener('click', () => {
    document.querySelectorAll('.nav-dropdown').forEach((d) => {
      d.classList.remove('open');
      d.querySelector('.nav-dropdown-btn')?.setAttribute('aria-expanded', 'false');
    });
  });

  const mobileMenuBtn = document.getElementById('mobileMenuBtn');
  const mobileNav = document.getElementById('mobileNav');
  mobileMenuBtn?.addEventListener('click', () => {
    const open = mobileNav?.classList.toggle('open');
    mobileMenuBtn.setAttribute('aria-expanded', String(!!open));
  });

  const historyBtn = document.getElementById('historyBtn');
  const historyPanel = document.getElementById('historyPanel');
  const historyOverlay = document.getElementById('historyOverlay');
  const closeHistory = document.getElementById('closeHistory');
  function openHistory() { historyPanel?.classList.add('open'); historyOverlay?.classList.add('open'); renderHistory(); }
  function closeHistoryPanel() { historyPanel?.classList.remove('open'); historyOverlay?.classList.remove('open'); }
  historyBtn?.addEventListener('click', openHistory);
  closeHistory?.addEventListener('click', closeHistoryPanel);
  historyOverlay?.addEventListener('click', closeHistoryPanel);

  function renderHistory() {
    const list = document.getElementById('historyList');
    if (!list) return;
    const items: Array<{style:string;input:string;output:string;date:string}> = JSON.parse(localStorage.getItem('oe-history') || '[]');
    if (!items.length) {
      list.innerHTML = '<div class="history-empty"><div style="margin-bottom:12px;">📜</div><p>No translations yet.<br/>Your history will appear here.</p></div>';
      return;
    }
    list.innerHTML = items.map((item, i) => `
      <div class="history-item">
        <div class="history-item-style">${item.style}</div>
        <div class="history-item-text">${item.input}</div>
        <div class="history-item-actions">
          <button class="btn btn-ghost btn-sm" onclick="copyHistory(${i})">Copy</button>
          <button class="btn btn-ghost btn-sm" onclick="downloadHistory(${i})">Download</button>
          <button class="btn btn-ghost btn-sm" onclick="deleteHistory(${i})">Delete</button>
        </div>
      </div>
    `).join('');
  }

  (window as any).copyHistory = (i: number) => {
    const items = JSON.parse(localStorage.getItem('oe-history') || '[]');
    if (items[i]) navigator.clipboard.writeText(items[i].output || items[i].input);
  };
  (window as any).downloadHistory = (i: number) => {
    const items = JSON.parse(localStorage.getItem('oe-history') || '[]');
    const item = items[i];
    if (!item) return;
    const text = item.output || item.input || '';
    if ((window as any).downloadText) {
      (window as any).downloadText(text, 'translation-' + (item.style || 'history') + '.txt');
    }
  };
  (window as any).deleteHistory = (i: number) => {
    const items = JSON.parse(localStorage.getItem('oe-history') || '[]');
    items.splice(i, 1);
    localStorage.setItem('oe-history', JSON.stringify(items));
    renderHistory();
  };

  document.getElementById('clearAllHistory')?.addEventListener('click', () => {
    localStorage.removeItem('oe-history');
    renderHistory();
  });

  (window as any).saveToHistory = (style: string, input: string, output: string) => {
    const items: Array<{style:string;input:string;output:string;date:string}> = JSON.parse(localStorage.getItem('oe-history') || '[]');
    items.unshift({ style, input, output, date: new Date().toISOString() });
    if (items.length > 50) items.splice(50);
    localStorage.setItem('oe-history', JSON.stringify(items));
  };

  document.querySelectorAll('.faq-question').forEach(btn => {
    btn.addEventListener('click', () => {
      const item = btn.closest('.faq-item');
      item?.classList.toggle('open');
    });
  });
</script>
<script src={`${import.meta.env.BASE_URL}translator.js`} defer></script>
<script src={`${import.meta.env.BASE_URL}speech-input.js`} defer></script>
</body>
</html>
