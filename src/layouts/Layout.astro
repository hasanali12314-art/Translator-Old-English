        <a href="/aramaic-translator/" class="mobile-nav-sub">Aramaic</a>
        <a href="/ancient-languages/" class="mobile-nav-sub" style="color:var(--gold);">See All →</a>
      </div>
      <div class="mobile-nav-group">
