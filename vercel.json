{
  "trailingSlash": true,
  "redirects": [
    {
      "source": "/index.php",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/about-us",
      "destination": "/about-us/",
      "permanent": true
    },
    {
      "source": "/contact-us",
      "destination": "/contact-us/",
      "permanent": true
    },
    {
      "source": "/all-languages",
      "destination": "/all-languages/",
      "permanent": true
    },
    {
      "source": "/all-languages/",
      "has": [
        {
          "type": "query",
          "key": "to"
        }
      ],
      "destination": "/all-languages/",
      "permanent": true
    },
    {
      "source": "/blog",
      "destination": "/blog/",
      "permanent": true
    },
    {
      "source": "/sitemap",
      "destination": "/sitemap/",
      "permanent": true
    },
    {
      "source": "/search",
      "destination": "/search/",
      "permanent": true
    },
    {
      "source": "/privacy-policy",
      "destination": "/privacy-policy/",
      "permanent": true
    },
    {
      "source": "/terms-and-conditions",
      "destination": "/terms-and-conditions/",
      "permanent": true
    },
    {
      "source": "/cookies",
      "destination": "/cookies/",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'self'; form-action 'self'; upgrade-insecure-requests; script-src 'self' 'unsafe-inline' 'wasm-unsafe-eval' https://cdn.jsdelivr.net https://cdnjs.cloudflare.com https://unpkg.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https:; font-src 'self' data:; connect-src 'self' https://api.mymemory.translated.net https://cdn.jsdelivr.net https://cdnjs.cloudflare.com https://unpkg.com blob:; worker-src 'self' blob: https://cdn.jsdelivr.net https://cdnjs.cloudflare.com; child-src 'self' blob:; media-src 'self' blob:; manifest-src 'self'"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(self), geolocation=(), payment=(), usb=()"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains; preload"
        }
      ]
    }
  ]
}
